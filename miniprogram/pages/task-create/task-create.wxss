/* iOS Task Create */
.task-create-page { min-height: 100vh; background: var(--color-background); }

.task-create-page__form { padding: 16rpx 32rpx 100rpx; }

.task-create-page__field { margin-bottom: 16rpx; }

.task-create-page__label {
  display: block; font-size: 24rpx; font-weight: 600;
  color: #A0A0A0; margin-bottom: 8rpx;
}

.task-create-page__input {
  background: #FFFFFF;
  border-radius: 12rpx; padding: 12rpx;
  font-size: 30rpx; color: #3C3C3C;
}

.task-create-page__textarea {
  background: #FFFFFF;
  border-radius: 12rpx; padding: 12rpx;
  font-size: 28rpx; min-height: 100rpx; width: 100%; box-sizing: border-box;
  color: #3C3C3C;
}

.task-create-page__category-row { display: flex; gap: 12rpx; }

.task-create-page__category-option {
  flex: 1; display: flex; flex-direction: column; align-items: center;
  gap: 8rpx; padding: 16rpx;
  background: #FFFFFF;
  border-radius: 16rpx;
  box-shadow: 0 0 0 2rpx transparent;
  transition: all 0.2s ease;
}
.task-create-page__category-option:active { transform: scale(0.96); }
.task-create-page__category-option--active {
  box-shadow: 0 0 0 2rpx #58CC02;
  background: rgba(88,204,2,0.08);
}

.task-create-page__category-icon { font-size: 32rpx; }
.task-create-page__category-name { font-size: 24rpx; color: #A0A0A0; }
.task-create-page__category-option--active .task-create-page__category-name { color: #58CC02; }

.task-create-page__type-row { display: flex; gap: 12rpx; }

.task-create-page__type-option {
  flex: 1; display: flex; flex-direction: column; align-items: center;
  gap: 4rpx; padding: 16rpx;
  background: #FFFFFF;
  border-radius: 16rpx;
  box-shadow: 0 0 0 2rpx transparent;
  transition: all 0.2s ease;
}
.task-create-page__type-option:active { transform: scale(0.96); }
.task-create-page__type-option--active {
  box-shadow: 0 0 0 2rpx #58CC02;
  background: rgba(88,204,2,0.08);
}

.task-create-page__type-icon { font-size: 28rpx; }
.task-create-page__type-name { font-size: 26rpx; font-weight: 500; color: #3C3C3C; }
.task-create-page__type-desc { font-size: 24rpx; color: #CFCFCF; }
.task-create-page__type-option--active .task-create-page__type-name { color: #58CC02; }
.task-create-page__type-option--active .task-create-page__type-desc { color: #58CC02; }

.task-create-page__slider-row { display: flex; align-items: center; gap: 8rpx; }

.task-create-page__slider-btn {
  width: 44rpx; height: 44rpx; border-radius: 50%;
  background: #FFFFFF; border: 2rpx solid #E8E8E8;
  display: flex; align-items: center; justify-content: center;
  font-size: 28rpx; font-weight: 600; color: #58CC02;
  flex-shrink: 0;
  transition: all 0.15s ease;
}
.task-create-page__slider-btn:active {
  transform: scale(0.88); background: #58CC02; color: #FFFFFF; border-color: #58CC02;
}
.task-create-page__slider { flex: 1; }
.task-create-page__slider-min, .task-create-page__slider-max {
  font-size: 24rpx; color: #CFCFCF; width: 32rpx; text-align: center;
}

.task-create-page__child-row { display: flex; gap: 8rpx; }

.task-create-page__child-option {
  padding: 8rpx 16rpx;
  background: #FFFFFF;
  border-radius: 100rpx; font-size: 26rpx;
  box-shadow: 0 0 0 2rpx transparent;
  transition: all 0.2s ease;
  color: #A0A0A0;
}
.task-create-page__child-option:active { transform: scale(0.96); }
.task-create-page__child-option--active {
  box-shadow: 0 0 0 2rpx #58CC02;
  background: rgba(88,204,2,0.08); color: #58CC02; font-weight: 600;
}

/* Footer */
.task-create-page__footer {
  position: fixed; bottom: 0; left: 0; right: 0;
  padding: 8rpx 32rpx calc(8rpx + env(safe-area-inset-bottom));
  background: rgba(255,255,255,0.95);
  box-shadow: 0 -1px 0 rgba(0,0,0,0.06);
}

/* Self-Challenge Toggle */
.task-create-page__self-challenge {
  display: flex; align-items: center; justify-content: space-between;
  padding: 24rpx; background: linear-gradient(135deg, #FFF9E6, #FFF3E0);
  border-radius: 20rpx; border: 2rpx solid #FFE0A0;
}

.task-create-page__sc-left {
  display: flex; align-items: center; gap: 14rpx;
}

.task-create-page__sc-icon { font-size: 44rpx; }

.task-create-page__sc-info { display: flex; flex-direction: column; gap: 2rpx; }

.task-create-page__sc-title {
  font-size: 28rpx; font-weight: 700; color: #3C3C3C;
}

.task-create-page__sc-desc {
  font-size: 22rpx; color: #A0A0A0;
}

.task-create-page__sc-toggle {
  width: 80rpx; height: 44rpx; border-radius: 22rpx;
  background: #E5E5EA; position: relative;
  transition: background 0.2s ease;
}

.task-create-page__sc-toggle--on {
  background: #FF9500;
}

.task-create-page__sc-toggle-knob {
  width: 36rpx; height: 36rpx; border-radius: 50%;
  background: #FFFFFF; position: absolute;
  top: 4rpx; left: 4rpx;
  box-shadow: 0 2rpx 4rpx rgba(0,0,0,0.1);
  transition: left 0.2s ease;
}

.task-create-page__sc-toggle--on .task-create-page__sc-toggle-knob {
  left: 40rpx;
}

.task-create-page__submit {
  width: 100%; height: 52rpx; line-height: 52rpx;
  background: #58CC02; color: #FFFFFF;
  border-radius: 12rpx; font-size: 28rpx; font-weight: 600;
  border: none; box-shadow: var(--shadow-glow-green);
  transition: all 0.2s ease;
  display: flex; align-items: center; justify-content: center;
  text-align: center;
}
.task-create-page__submit::after { border: none; }
.task-create-page__submit:active { transform: scale(0.97); opacity: 0.88; }
