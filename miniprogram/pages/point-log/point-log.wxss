/* iOS Point Log */
.pl-page { min-height: 100vh; background: var(--color-background); }

.pl-page__list { padding: 0 32rpx; }

.pl-page__record {
  display: flex; align-items: center; justify-content: space-between;
  padding: 12rpx;
  background: #FFFFFF;
  border-radius: 12rpx; margin-bottom: 8rpx;
  box-shadow: var(--shadow-card);
}
.pl-page__record:active { transform: scale(0.98); }

.pl-page__record-left { display: flex; align-items: center; gap: 12rpx; }
.pl-page__record-icon { font-size: 24rpx; }

.pl-page__record-note {
  display: block; font-size: 24rpx; color: #3C3C3C;
}

.pl-page__record-time { font-size: 24rpx; color: #CFCFCF; }

.pl-page__record-amount { font-size: 24rpx; font-weight: 700; }
