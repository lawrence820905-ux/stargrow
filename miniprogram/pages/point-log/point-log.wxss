/* iOS Point Log */
.pl-page { min-height: 100vh; background: #F2F2F7; }

.pl-page__list { padding: 0 32rpx; }

.pl-page__record {
  display: flex; align-items: center; justify-content: space-between;
  padding: 12rpx;
  background: #FFFFFF;
  border-radius: 12rpx; margin-bottom: 8rpx;
  box-shadow: 0 2px 16px rgba(0,0,0,0.04);
}
.pl-page__record:active { transform: scale(0.98); }

.pl-page__record-left { display: flex; align-items: center; gap: 12rpx; }
.pl-page__record-icon { font-size: 24rpx; }

.pl-page__record-note {
  display: block; font-size: 17rpx; color: #1d1d1f;
}

.pl-page__record-time { font-size: 12rpx; color: #C7C7CC; }

.pl-page__record-amount { font-size: 22rpx; font-weight: 700; }
