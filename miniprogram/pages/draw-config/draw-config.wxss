/* iOS Draw Config */
.draw-config-page { min-height: 100vh; background: #F2F2F7; }

.draw-config-page__content { padding: 16rpx 32rpx; }

.draw-config-page__segment {
  display: flex; background: #C6C6C8;
  border-radius: 10rpx; padding: 3rpx; margin-bottom: 24rpx;
}

.draw-config-page__segment-item {
  flex: 1; text-align: center; padding: 8rpx;
  border-radius: 8rpx; font-size: 26rpx; font-weight: 500;
  color: #8E8E93;
  transition: all 0.2s ease;
}
.draw-config-page__segment-item--active {
  background: #FFFFFF;
  color: #007AFF; box-shadow: 0 2px 16px rgba(0,0,0,0.04);
}

.draw-config-page__field { margin-bottom: 24rpx; }

.draw-config-page__label {
  display: block; font-size: 24rpx; color: #8E8E93;
  margin-bottom: 8rpx;
}

.draw-config-page__slider-row { display: flex; align-items: center; gap: 8rpx; }
.draw-config-page__slider { flex: 1; }
.draw-config-page__slider-min, .draw-config-page__slider-max {
  font-size: 22rpx; color: #C7C7CC;
}

.draw-config-page__slider-btn {
  width: 44rpx; height: 44rpx; border-radius: 50%;
  background: #FFFFFF; border: 2rpx solid #C6C6C8;
  display: flex; align-items: center; justify-content: center;
  font-size: 28rpx; font-weight: 600; color: #007AFF;
  flex-shrink: 0;
  transition: all 0.15s ease;
}
.draw-config-page__slider-btn:active {
  transform: scale(0.88); background: #007AFF; color: #FFFFFF; border-color: #007AFF;
}

.draw-config-page__section { margin-bottom: 24rpx; }

.draw-config-page__section-title {
  font-size: 24rpx; font-weight: 600; margin-bottom: 12rpx; display: block;
  color: #1d1d1f;
}

.draw-config-page__item {
  padding: 12rpx; border-radius: 12rpx;
  margin-bottom: 8rpx; background: #FFFFFF;
  transition: all 0.2s ease;
}
.draw-config-page__item:active { opacity: 0.7; }

.draw-config-page__item-header { display: flex; align-items: center; gap: 8rpx; }
.draw-config-page__item-icon { font-size: 26rpx; }

.draw-config-page__item-name {
  flex: 1; font-size: 26rpx; font-weight: 500; color: #1d1d1f;
}

.draw-config-page__item-weight { font-size: 22rpx; color: #C7C7CC; }

.draw-config-page__item-delete {
  width: 40rpx; height: 40rpx; display: flex; align-items: center; justify-content: center;
  color: #FF3B30; font-size: 24rpx;
}
.draw-config-page__item-delete:active { transform: scale(0.85); }

.draw-config-page__item-prob {
  margin-top: 8rpx; font-size: 22rpx; color: #C7C7CC;
}

.draw-config-page__add-btn {
  text-align: center; padding: 16rpx;
  border-radius: 12rpx;
  background: #FFFFFF;
  font-size: 26rpx; color: #007AFF; font-weight: 500;
}
.draw-config-page__add-btn:active { transform: scale(0.97); }

.draw-config-page__save {
  width: 100%; height: 52rpx; line-height: 52rpx;
  background: #007AFF; color: #FFFFFF;
  border-radius: 12rpx; font-size: 28rpx; font-weight: 600;
  border: none; box-shadow: 0 4px 16px rgba(0,122,255,0.25);
  transition: all 0.2s ease;
}
.draw-config-page__save::after { border: none; }
.draw-config-page__save:active { transform: scale(0.97); }

.draw-config-page__modal-btns { display: flex; gap: 12rpx; margin-top: 8rpx; }

.draw-config-page__modal-cancel {
  flex: 1; height: 48rpx; line-height: 48rpx;
  background: #F2F2F7; color: #8E8E93;
  border-radius: 12rpx; font-size: 28rpx; border: none;
}
.draw-config-page__modal-cancel::after { border: none; }

.draw-config-page__modal-confirm {
  flex: 1; height: 48rpx; line-height: 48rpx;
  background: #007AFF; color: #FFFFFF;
  border-radius: 12rpx; font-size: 28rpx; font-weight: 600; border: none;
}
.draw-config-page__modal-confirm::after { border: none; }

/* Modal */
.draw-config-page__overlay {
  position: fixed; top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.4); z-index: 200;
  display: flex; align-items: flex-end;
  animation: overlay-fade 0.25s ease forwards;
}
@keyframes overlay-fade { from { opacity: 0; } to { opacity: 1; } }

.draw-config-page__modal {
  width: 100%; max-height: 80vh;
  background: #FFFFFF;
  border-radius: 20rpx 20rpx 0 0;
  padding: 24rpx; overflow-y: auto;
  animation: slide-in 0.3s ease forwards;
}
@keyframes slide-in { from { transform: translateY(100%); } to { transform: translateY(0); } }

.draw-config-page__modal-title {
  font-size: 28rpx; font-weight: 600; text-align: center; display: block;
  margin-bottom: 24rpx; color: #1d1d1f;
}

.draw-config-page__input {
  background: #F2F2F7; border-radius: 10rpx;
  padding: 12rpx; font-size: 28rpx;
}

.draw-config-page__type-row { display: flex; gap: 8rpx; }

.draw-config-page__type-option {
  flex: 1; text-align: center; padding: 12rpx;
  border-radius: 10rpx;
  background: #F2F2F7; font-size: 24rpx;
  color: #8E8E93;
  transition: all 0.2s ease;
}
.draw-config-page__type-option:active { transform: scale(0.96); }
.draw-config-page__type-option--active {
  background: #007AFF; color: #FFFFFF;
  box-shadow: 0 2px 12px rgba(0,122,255,0.2);
}
