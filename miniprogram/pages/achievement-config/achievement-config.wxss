/* iOS Achievement Config */
.ac-page { min-height: 100vh; background: #F2F2F7; }

.ac-page__content { padding: 16rpx 32rpx; }

.ac-page__section { margin-bottom: 24rpx; }

.ac-page__section-label {
  font-size: 24rpx; color: #8E8E93;
  padding: 0 8rpx 8rpx;
  display: block; font-weight: 500;
}

.ac-page__card {
  background: #FFFFFF;
  border-radius: 16rpx; overflow: hidden;
  box-shadow: 0 2px 16px rgba(0,0,0,0.04);
}

.ac-page__item {
  display: flex; align-items: center; gap: 12rpx;
  padding: 16rpx;
  border-bottom: 0.5px solid #C6C6C8;
}
.ac-page__item:last-child { border-bottom: none; }

.ac-page__item-icon { font-size: 40rpx; flex-shrink: 0; }

.ac-page__item-info { flex: 1; display: flex; flex-direction: column; gap: 4rpx; }

.ac-page__item-name {
  font-size: 28rpx; font-weight: 600; color: #1d1d1f;
}

.ac-page__item-desc {
  font-size: 22rpx; color: #8E8E93;
}

.ac-page__item-status {
  font-size: 20rpx; color: #C7C7CC; flex-shrink: 0;
}

.ac-page__item-actions {
  display: flex; align-items: center; gap: 8rpx; flex-shrink: 0;
}

.ac-page__item-toggle {
  padding: 6rpx 16rpx; border-radius: 100rpx;
  font-size: 20rpx; background: #C6C6C8; color: #8E8E93;
  transition: all 0.2s ease;
}
.ac-page__item-toggle--on {
  background: #34C759; color: #FFFFFF;
}

.ac-page__item-edit {
  width: 44rpx; height: 44rpx; display: flex;
  align-items: center; justify-content: center;
  color: #007AFF; font-size: 28rpx;
}
.ac-page__item-edit:active { transform: scale(0.85); }

.ac-page__item-reset {
  width: 44rpx; height: 44rpx; display: flex;
  align-items: center; justify-content: center;
  color: #FF9500; font-size: 28rpx;
}
.ac-page__item-reset:active { transform: scale(0.85); }

.ac-page__item-delete {
  width: 44rpx; height: 44rpx; display: flex;
  align-items: center; justify-content: center;
  color: #FF3B30; font-size: 24rpx;
}
.ac-page__item-delete:active { transform: scale(0.85); }

.ac-page__empty {
  padding: 32rpx; text-align: center;
  font-size: 24rpx; color: #C7C7CC;
}

.ac-page__add-btn {
  width: 100%; height: 52rpx; line-height: 52rpx;
  background: #007AFF; color: #FFFFFF;
  border-radius: 12rpx; font-size: 28rpx; font-weight: 600;
  border: none; box-shadow: 0 4rpx 16rpx rgba(0,122,255,0.3);
  margin-bottom: 24rpx;
}
.ac-page__add-btn::after { border: none; }
.ac-page__add-btn:active { transform: scale(0.97); }

/* Modal */
.ac-page__overlay {
  position: fixed; top: 0; left: 0; right: 0; bottom: 0;
  z-index: 200;
  display: flex; align-items: flex-end;
}
.ac-page__overlay-bg {
  position: absolute; top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.4);
}

.ac-page__modal {
  position: relative; z-index: 1;
  width: 100%; max-height: 80vh;
  background: #FFFFFF;
  border-radius: 20rpx 20rpx 0 0;
  padding: 24rpx; overflow-y: auto;
  animation: ac-slide-in 0.3s ease forwards;
}
@keyframes ac-slide-in { from { transform: translateY(100%); } to { transform: translateY(0); } }

.ac-page__modal-title {
  font-size: 28rpx; font-weight: 700; text-align: center;
  margin-bottom: 24rpx; color: #1d1d1f;
}

.ac-page__field { margin-bottom: 20rpx; }

.ac-page__label {
  display: block; font-size: 24rpx; color: #8E8E93;
  margin-bottom: 8rpx;
}

.ac-page__input {
  background: #F2F2F7; border-radius: 10rpx;
  padding: 12rpx; font-size: 28rpx; color: #1d1d1f;
}

.ac-page__type-row { display: flex; gap: 8rpx; }

.ac-page__type-option {
  flex: 1; text-align: center; padding: 12rpx;
  border-radius: 10rpx;
  background: #F2F2F7; font-size: 24rpx;
  color: #8E8E93;
  transition: all 0.2s ease;
}
.ac-page__type-option:active { transform: scale(0.96); }
.ac-page__type-option--active {
  background: #007AFF; color: #FFFFFF;
}

.ac-page__slider-row { display: flex; align-items: center; gap: 8rpx; }
.ac-page__slider { flex: 1; }

.ac-page__slider-btn {
  width: 44rpx; height: 44rpx; border-radius: 50%;
  background: #F2F2F7; border: 2rpx solid #C6C6C8;
  display: flex; align-items: center; justify-content: center;
  font-size: 28rpx; font-weight: 600; color: #007AFF;
  flex-shrink: 0;
}
.ac-page__slider-btn:active {
  transform: scale(0.88); background: #007AFF; color: #FFFFFF; border-color: #007AFF;
}

.ac-page__modal-btns { display: flex; gap: 12rpx; margin-top: 8rpx; }

.ac-page__modal-cancel {
  flex: 1; height: 48rpx; line-height: 48rpx;
  background: #F2F2F7; color: #8E8E93;
  border-radius: 12rpx; font-size: 28rpx; border: none;
}
.ac-page__modal-cancel::after { border: none; }

.ac-page__modal-confirm {
  flex: 1; height: 48rpx; line-height: 48rpx;
  background: #007AFF; color: #FFFFFF;
  border-radius: 12rpx; font-size: 28rpx; font-weight: 600; border: none;
}
.ac-page__modal-confirm::after { border: none; }
