/* iOS Tasks */
.tasks-page { min-height: 100vh; background: #F2F2F7; }

/* Header */
.tasks-page__header {
  display: flex; align-items: center; justify-content: space-between;
  padding: 8rpx 32rpx;
  background: #FFFFFF;
  position: sticky; top: 0; z-index: 99;
}

.tasks-page__title {
  font-size: 34rpx; font-weight: 600;
  color: #1d1d1f; letter-spacing: -0.3rpx;
}

.tasks-page__add-btn {
  padding: 10rpx 24rpx; border-radius: 100rpx;
  background: #007AFF;
  display: flex; align-items: center; justify-content: center;
  box-shadow: 0 4rpx 16rpx rgba(0,122,255,0.3);
}
.tasks-page__add-btn:active { transform: scale(0.94); opacity: 0.85; }

.tasks-page__add-text {
  font-size: 24rpx; color: #FFFFFF; font-weight: 600;
  text-align: center; line-height: 1;
}

/* Filters */
.tasks-page__filters { padding: 8rpx 32rpx; }

.tasks-page__category-tabs { white-space: nowrap; margin-bottom: 8rpx; }

.tasks-page__tab {
  display: inline-flex; padding: 8rpx 18rpx;
  border-radius: 100rpx; font-size: 26rpx; font-weight: 500;
  color: #8E8E93;
  background: #FFFFFF;
  margin-right: 8rpx;
  transition: all 0.2s ease;
}
.tasks-page__tab:active { transform: scale(0.95); }
.tasks-page__tab--active {
  background: #007AFF; color: #FFFFFF;
  box-shadow: 0 2rpx 12rpx rgba(0,122,255,0.3);
}

.tasks-page__type-tabs { display: flex; gap: 8rpx; margin-bottom: 8rpx; }

.tasks-page__type-tab {
  padding: 8rpx 18rpx; border-radius: 100rpx;
  font-size: 26rpx; color: #8E8E93; font-weight: 500;
  background: #FFFFFF;
  transition: all 0.2s ease;
}
.tasks-page__type-tab:active { transform: scale(0.95); }
.tasks-page__type-tab--active {
  background: #007AFF; color: #FFFFFF;
}

/* List */
.tasks-page__list { padding: 8rpx 32rpx; }

.tasks-page__load-more {
  text-align: center; padding: 16rpx;
  font-size: 24rpx; color: #C7C7CC;
}

/* Task Detail Modal */
.tasks-page__overlay {
  position: fixed; top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.4); z-index: 200;
  display: flex; align-items: flex-end;
}

.tasks-page__detail-modal {
  width: 100%; max-height: 70vh;
  background: #FFFFFF;
  border-radius: 20rpx 20rpx 0 0;
  padding: 16rpx 32rpx 32rpx;
  animation: tasks-slide-in 0.3s ease forwards;
}
@keyframes tasks-slide-in { from { transform: translateY(100%); } to { transform: translateY(0); } }

.tasks-page__detail-handle {
  display: flex; justify-content: center; padding: 8rpx 0 16rpx;
}

.tasks-page__detail-handle-bar {
  width: 48rpx; height: 6rpx; background: #C6C6C8; border-radius: 3rpx;
}

.tasks-page__detail-title {
  font-size: 30rpx; font-weight: 600; color: #1d1d1f;
  display: block; margin-bottom: 8rpx;
}

.tasks-page__detail-desc {
  font-size: 26rpx; color: #8E8E93;
  display: block; margin-bottom: 16rpx; line-height: 1.5;
}

.tasks-page__detail-info {
  background: #F2F2F7; border-radius: 12rpx; padding: 12rpx 16rpx;
  display: flex; flex-direction: column; gap: 8rpx;
}

.tasks-page__detail-row {
  display: flex; align-items: center; justify-content: space-between;
}

.tasks-page__detail-label {
  font-size: 26rpx; color: #8E8E93;
}

.tasks-page__detail-val {
  font-size: 26rpx; font-weight: 500; color: #1d1d1f;
}

.tasks-page__detail-actions { margin-top: 24rpx; }

.tasks-page__detail-delete {
  text-align: center; padding: 16rpx;
  font-size: 28rpx; color: #FF3B30; font-weight: 500;
  background: #FFF2F2; border-radius: 12rpx;
}
.tasks-page__detail-delete:active { background: #FFE5E5; }
