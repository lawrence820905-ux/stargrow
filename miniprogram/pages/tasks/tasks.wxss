/* Duolingo ABC Tasks */
.tasks-page { min-height: 100vh; background: var(--color-background); }

.tasks-page__toolbar {
  display: flex; gap: 12rpx; padding: 8rpx 32rpx;
}

.tasks-page__add-btn {
  padding: 10rpx 22rpx; border-radius: 100rpx;
  background: linear-gradient(135deg, #46A800, #58CC02);
  display: inline-flex; align-items: center; justify-content: center;
  border: 2rpx solid transparent;
}
.tasks-page__add-btn:active { transform: scale(0.94); opacity: 0.85; }

.tasks-page__add-btn--random {
  background: linear-gradient(135deg, #1498D4, #1CB0F6);
}

.tasks-page__add-text {
  font-size: 26rpx; color: #FFFFFF; font-weight: 600;
}

/* Filters */
.tasks-page__filters { padding: 8rpx 32rpx; }

.tasks-page__category-tabs { white-space: nowrap; margin-bottom: 8rpx; }

.tasks-page__tab {
  display: inline-flex; padding: 10rpx 22rpx;
  border-radius: 100rpx; font-size: 26rpx; font-weight: 600;
  color: #A0A0A0;
  background: #FFFFFF;
  border: 2rpx solid #E8E8E8;
  margin-right: 8rpx;
  transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
}
.tasks-page__tab:active { transform: scale(0.95); }
.tasks-page__tab--active {
  background: #58CC02; color: #FFFFFF; border-color: #58CC02;
  box-shadow: 0 4px 16px rgba(88,204,2,0.25);
}

.tasks-page__type-tabs { display: flex; gap: 8rpx; margin-bottom: 8rpx; }

.tasks-page__type-tab {
  padding: 10rpx 22rpx; border-radius: 100rpx;
  font-size: 26rpx; color: #A0A0A0; font-weight: 600;
  background: #FFFFFF;
  border: 2rpx solid #E8E8E8;
  transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
}
.tasks-page__type-tab:active { transform: scale(0.95); }
.tasks-page__type-tab--active {
  background: #1CB0F6; color: #FFFFFF; border-color: #1CB0F6;
  box-shadow: 0 4px 16px rgba(28,176,246,0.25);
}

/* List */
.tasks-page__list { padding: 8rpx 32rpx; }

.tasks-page__load-more {
  text-align: center; padding: 16rpx;
  font-size: 24rpx; color: #CFCFCF; font-weight: 500;
}

/* Task Detail Modal — 全屏展示，上面不留白 */
.tasks-page__overlay {
  position: fixed; top: 0; left: 0; right: 0; bottom: 0;
  background: #FFFFFF; z-index: 200;
  display: flex; flex-direction: column;
}

.tasks-page__detail-modal {
  width: 100%; height: 100%;
  display: flex; flex-direction: column;
  padding: 0 32rpx;
  box-sizing: border-box;
}

.tasks-page__detail-scroll {
  flex: 1; overflow-y: auto;
  padding-top: 24rpx;
}

@keyframes tasks-slide-in { from { transform: translateY(100%); } to { transform: translateY(0); } }

.tasks-page__detail-handle {
  display: flex; align-items: center; justify-content: space-between;
  padding: 24rpx 0 16rpx;
  flex-shrink: 0;
}

.tasks-page__detail-handle-bar {
  width: 48rpx; height: 6rpx; background: #CFCFCF; border-radius: 3rpx;
}

.tasks-page__detail-close {
  font-size: 28rpx; color: #58CC02; font-weight: 600;
  padding: 8rpx 4rpx;
}

.tasks-page__detail-title {
  font-size: 32rpx; font-weight: 700; color: #3C3C3C;
  display: block; margin-bottom: 8rpx;
}

.tasks-page__detail-desc {
  font-size: 26rpx; color: #A0A0A0;
  display: block; margin-bottom: 16rpx; line-height: 1.5;
}

.tasks-page__detail-info {
  background: #F5F5F5; border-radius: 16rpx; padding: 12rpx 16rpx;
  display: flex; flex-direction: column; gap: 8rpx;
}

.tasks-page__detail-row {
  display: flex; align-items: center; justify-content: space-between;
}

.tasks-page__detail-label {
  font-size: 26rpx; color: #A0A0A0;
}

.tasks-page__detail-val {
  font-size: 26rpx; font-weight: 600; color: #3C3C3C;
}

.tasks-page__detail-actions {
  margin-top: 24rpx; display: flex; gap: 16rpx;
  padding-bottom: env(safe-area-inset-bottom, 16rpx);
}

.tasks-page__detail-edit {
  flex: 1; text-align: center; padding: 16rpx;
  font-size: 28rpx; color: #58CC02; font-weight: 600;
  background: #F0FFE8; border-radius: 16rpx;
}
.tasks-page__detail-edit:active { background: #E0FFD0; }

.tasks-page__detail-delete {
  flex: 1; text-align: center; padding: 16rpx;
  font-size: 28rpx; color: #FF4B4B; font-weight: 600;
  background: #FFF0F0; border-radius: 16rpx;
}

/* Propose Modal */
.tasks-page__detail-input {
  flex: 1; font-size: 26rpx; color: #3C3C3C;
  border-bottom: 2rpx solid #E5E5EA; padding: 8rpx 0;
}

.tasks-page__propose-cats {
  display: flex; gap: 12rpx; flex-wrap: wrap;
}

.tasks-page__propose-cat {
  padding: 10rpx 20rpx; border-radius: 100rpx;
  font-size: 24rpx; font-weight: 500;
  background: #F2F2F7; color: #8E8E93;
  transition: all 0.2s ease;
}

.tasks-page__propose-cat--active {
  background: #007AFF; color: #FFFFFF;
}

.tasks-page__propose-suggestions {
  display: flex; flex-wrap: wrap; gap: 8rpx; flex: 1;
}

.tasks-page__propose-suggestion {
  padding: 8rpx 16rpx; border-radius: 100rpx;
  font-size: 22rpx; font-weight: 500;
  background: #F2F2F7; color: #8E8E93;
  transition: all 0.2s ease;
}
.tasks-page__propose-suggestion:active { transform: scale(0.95); }
.tasks-page__propose-suggestion--active {
  background: #FF9500; color: #FFFFFF;
}
.tasks-page__detail-delete:active { background: #FFE5E5; }
