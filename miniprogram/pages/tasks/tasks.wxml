<view class="tasks-page">
  <!-- Nav -->
  <view class="tasks-page__header">
    <text class="tasks-page__title">任务</text>
    <view class="tasks-page__header-btns">
      <view class="tasks-page__add-btn tasks-page__add-btn--propose" bindtap="onProposeTask">
        <text class="tasks-page__add-text">💡 我想试试</text>
      </view>
      <view class="tasks-page__add-btn tasks-page__add-btn--random" bindtap="onRandomTasks">
        <text class="tasks-page__add-text">随机任务</text>
      </view>
      <view class="tasks-page__add-btn" bindtap="onCreateTask">
        <text class="tasks-page__add-text">新建任务</text>
      </view>
    </view>
  </view>

  <!-- Child Switcher -->
  <child-switcher children="{{children}}" activeId="{{activeChildId}}" bind:change="onChildChange" />

  <!-- Filters -->
  <view class="tasks-page__filters">
    <scroll-view class="tasks-page__category-tabs" scroll-x show-scrollbar="{{false}}">
      <view
        class="tasks-page__tab {{activeCategory === item.key ? 'tasks-page__tab--active' : ''}}"
        wx:for="{{categories}}"
        wx:key="key"
        data-key="{{item.key}}"
        bindtap="onCategoryChange"
      >
        <text>{{item.name}}</text>
      </view>
    </scroll-view>
    <view class="tasks-page__type-tabs">
      <view
        class="tasks-page__type-tab {{activeTaskType === item.key ? 'tasks-page__type-tab--active' : ''}}"
        wx:for="{{taskTypes}}"
        wx:key="key"
        data-key="{{item.key}}"
        bindtap="onTaskTypeChange"
      >
        <text>{{item.name}}</text>
      </view>
    </view>
  </view>

  <!-- Task List -->
  <view class="tasks-page__list" wx:if="{{!loading}}">
    <block wx:if="{{tasks.length > 0}}">
      <task-card
        wx:for="{{tasks}}"
        wx:key="_id"
        task="{{item}}"
        bind:tasktap="onTaskTap"
      />
    </block>
    <empty-state wx:else icon="📋" text="还没有任务" hint="创建每日任务，帮孩子养成好习惯" />
    <view wx:if="{{hasMore}}" class="tasks-page__load-more" bindtap="loadMore">
      <text>加载更多</text>
    </view>
  </view>

  <view class="tasks-page__list" wx:else>
    <skeleton-card wx:for="{{3}}" wx:key="index" />
  </view>

  <!-- Task Detail — 全屏展示 -->
  <view class="tasks-page__overlay" wx:if="{{showDetail}}">
    <view class="tasks-page__detail-modal">
      <view class="tasks-page__detail-handle">
        <view class="tasks-page__detail-handle-bar"></view>
        <text class="tasks-page__detail-close" bindtap="onCloseDetail">完成</text>
      </view>

      <scroll-view class="tasks-page__detail-scroll" scroll-y enhanced show-scrollbar="{{false}}">
        <text class="tasks-page__detail-title">{{detailTask.title}}</text>
        <text class="tasks-page__detail-desc" wx:if="{{detailTask.description}}">{{detailTask.description}}</text>

        <view class="tasks-page__detail-info">
          <view class="tasks-page__detail-row">
            <text class="tasks-page__detail-label">分类</text>
            <text class="tasks-page__detail-val">{{detailTask.category || '未分类'}}</text>
          </view>
          <view class="tasks-page__detail-row">
            <text class="tasks-page__detail-label">积分</text>
            <text class="tasks-page__detail-val">⭐ {{detailTask.status === 'completed' ? detailTask.pointsAwarded : detailTask.basePoints}}</text>
          </view>
          <view class="tasks-page__detail-row">
            <text class="tasks-page__detail-label">状态</text>
            <text class="tasks-page__detail-val {{detailTask.status === 'completed' ? 'color-green' : 'color-orange'}}">
              {{detailTask.status === 'completed' ? '已完成' : '待完成'}}
            </text>
          </view>
          <view class="tasks-page__detail-row" wx:if="{{detailTask.completedAt}}">
            <text class="tasks-page__detail-label">完成时间</text>
            <text class="tasks-page__detail-val">{{detailTask.createdAtText}}</text>
          </view>
        </view>

        <view class="tasks-page__detail-actions">
          <view class="tasks-page__detail-edit" bindtap="onEditTask">
            <text>编辑任务</text>
          </view>
          <view class="tasks-page__detail-delete" bindtap="onDeleteTask">
            <text>删除任务</text>
          </view>
        </view>
      </scroll-view>
    </view>
  </view>

  <!-- Propose Task Modal -->
  <view class="tasks-page__overlay" wx:if="{{showPropose}}">
    <view class="tasks-page__detail-modal">
      <view class="tasks-page__detail-handle">
        <view class="tasks-page__detail-handle-bar"></view>
        <text class="tasks-page__detail-close" bindtap="onClosePropose">完成</text>
      </view>
      <scroll-view class="tasks-page__detail-scroll" scroll-y enhanced show-scrollbar="{{false}}">
        <text class="tasks-page__detail-title">💡 我想试试...</text>
        <text class="tasks-page__detail-desc">和孩子一起讨论，孩子想尝试做什么？</text>

        <view class="tasks-page__detail-info">
          <view class="tasks-page__detail-row">
            <text class="tasks-page__detail-label">任务名称</text>
            <input class="tasks-page__detail-input" placeholder="比如：每天读一本书" value="{{proposeTitle}}" bindinput="onProposeTitleInput" />
          </view>
          <view class="tasks-page__detail-row">
            <text class="tasks-page__detail-label">分类</text>
            <view class="tasks-page__propose-cats">
              <view
                class="tasks-page__propose-cat {{proposeCategory === item.key ? 'tasks-page__propose-cat--active' : ''}}"
                wx:for="{{categories}}"
                wx:key="key"
                data-key="{{item.key}}"
                bindtap="onProposeCatChange"
              >
                <text>{{item.icon}} {{item.name}}</text>
              </view>
            </view>
          </view>
        </view>

        <view class="tasks-page__detail-actions">
          <view class="tasks-page__detail-edit" bindtap="onSubmitPropose">
            <text>提交提议</text>
          </view>
        </view>
      </scroll-view>
    </view>
  </view>

  <view class="safe-area-bottom" style="height: 160rpx;"></view>
</view>
