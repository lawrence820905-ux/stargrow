<view class="login-page">
  <view class="login-page__orb login-page__orb--top"></view>
  <view class="login-page__orb login-page__orb--bottom"></view>

  <!-- Hero -->
  <view class="login-page__hero">
    <view class="login-page__logo-wrap">
      <text class="login-page__logo">🌳</text>
    </view>
    <text class="login-page__app-name">成长派克</text>
    <text class="login-page__slogan">陪伴孩子快乐成长</text>
  </view>

  <!-- Feature Cards -->
  <view class="login-page__features">
    <view class="login-page__feature">
      <view class="login-page__feature-icon-wrap login-page__feature-icon-wrap--blue">
        <text class="login-page__feature-icon">📝</text>
      </view>
      <view class="login-page__feature-info">
        <text class="login-page__feature-title">任务打卡</text>
        <text class="login-page__feature-sub">完成任务获得积分奖励</text>
      </view>
    </view>
    <view class="login-page__feature">
      <view class="login-page__feature-icon-wrap login-page__feature-icon-wrap--orange">
        <text class="login-page__feature-icon">📦</text>
      </view>
      <view class="login-page__feature-info">
        <text class="login-page__feature-title">宝箱抽奖</text>
        <text class="login-page__feature-sub">积分开宝箱赢取好礼</text>
      </view>
    </view>
    <view class="login-page__feature">
      <view class="login-page__feature-icon-wrap login-page__feature-icon-wrap--green">
        <text class="login-page__feature-icon">🏅</text>
      </view>
      <view class="login-page__feature-info">
        <text class="login-page__feature-title">成就徽章</text>
        <text class="login-page__feature-sub">解锁成就见证成长轨迹</text>
      </view>
    </view>
  </view>

  <!-- Action Area -->
  <view class="login-page__action">
    <button class="login-page__btn" bindtap="onLogin" loading="{{loading}}" disabled="{{loading || showJoin}}">
      <text wx:if="{{!loading}}">微信一键登录 · 创建新家庭</text>
      <text wx:else>登录中...</text>
    </button>

    <view class="login-page__divider">
      <view class="login-page__divider-line"></view>
      <text class="login-page__divider-text">或</text>
      <view class="login-page__divider-line"></view>
    </view>

    <view class="login-page__join">
      <input
        class="login-page__invite-input"
        placeholder="输入6位邀请码"
        value="{{inviteCode}}"
        bindinput="onInviteInput"
        maxlength="6"
        disabled="{{loading}}"
      />
      <button class="login-page__join-btn" bindtap="onJoinFamily" loading="{{loading}}" disabled="{{!inviteCode || inviteCode.length < 6 || loading}}">
        加入家庭
      </button>
    </view>

    <text class="login-page__hint">每个微信号对应一个独立的家庭空间</text>
    <text class="login-page__hint">多个家长可通过邀请码加入同一家庭</text>
  </view>
</view>
