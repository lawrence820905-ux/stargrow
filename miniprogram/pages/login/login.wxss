/* Duolingo ABC Login 鈥?playful, bold, bouncy */
.login-page {
  min-height: 100vh;
  background: linear-gradient(180deg, var(--color-background) 0%, var(--color-background-white) 40%);
  display: flex; flex-direction: column; align-items: center;
  padding: 120rpx 40rpx 60rpx;
  position: relative; overflow: hidden;
  box-sizing: border-box;
}

/* Ambient orbs 鈥?more vibrant */
.login-page__orb {
  position: absolute; border-radius: 50%; pointer-events: none;
}
.login-page__orb--top {
  top: -120rpx; right: -80rpx;
  width: 360rpx; height: 360rpx;
  background: radial-gradient(circle, rgba(88,204,2,0.12) 0%, transparent 70%);
}
.login-page__orb--bottom {
  bottom: 180rpx; left: -100rpx;
  width: 300rpx; height: 300rpx;
  background: radial-gradient(circle, rgba(28,176,246,0.10) 0%, transparent 70%);
}

/* Hero */
.login-page__hero {
  display: flex; flex-direction: column; align-items: center;
  margin-bottom: 60rpx; position: relative; z-index: 1;
}

.login-page__logo-wrap {
  width: 160rpx; height: 160rpx; border-radius: 50%;
  background: #FFFFFF;
  box-shadow: 0 12px 48px rgba(88,204,2,0.15), 0 4px 12px rgba(0,0,0,0.06);
  display: flex; align-items: center; justify-content: center;
  margin-bottom: 28rpx;
  animation: logo-float 4s ease-in-out infinite;
}

@keyframes logo-float {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-12rpx); }
}

.login-page__logo { font-size: 80rpx; line-height: 1; }

.login-page__app-name {
  font-size: 40rpx; font-weight: 800;
  color: #3C3C3C; letter-spacing: 6rpx;
  margin-bottom: 8rpx;
}

.login-page__slogan {
  font-size: 26rpx; color: #A0A0A0; letter-spacing: 4rpx; font-weight: 500;
}

/* Feature Cards */
.login-page__features {
  display: flex; flex-direction: column; gap: 14rpx;
  width: 100%; margin-bottom: 60rpx; position: relative; z-index: 1;
}

.login-page__feature {
  display: flex; align-items: center; gap: 18rpx;
  padding: 20rpx 20rpx;
  background: #FFFFFF;
  border-radius: 24rpx;
  box-shadow: 0 4px 0 rgba(0,0,0,0.06), 0 2px 8px rgba(0,0,0,0.04);
}
.login-page__feature:active { transform: scale(0.975); }

.login-page__feature-icon-wrap {
  width: 72rpx; height: 72rpx; border-radius: 20rpx;
  display: flex; align-items: center; justify-content: center; flex-shrink: 0;
}
.login-page__feature-icon-wrap--blue   { background: rgba(28,176,246,0.10); }
.login-page__feature-icon-wrap--orange { background: rgba(255,150,0,0.10); }
.login-page__feature-icon-wrap--green  { background: rgba(88,204,2,0.10); }

.login-page__feature-icon { font-size: 36rpx; line-height: 1; }

.login-page__feature-info { display: flex; flex-direction: column; gap: 4rpx; flex: 1; }

.login-page__feature-title {
  font-size: 28rpx; color: #3C3C3C; font-weight: 700;
}
.login-page__feature-sub {
  font-size: 24rpx; color: #A0A0A0;
}

/* Action */
.login-page__action {
  width: 100%; display: flex; flex-direction: column; align-items: center;
  position: relative; z-index: 1;
}

.login-page__btn {
  width: 100%; height: 56rpx; line-height: 56rpx;
  background: #58CC02; color: #FFFFFF;
  border-radius: 100rpx; font-size: 30rpx; font-weight: 700;
  border: none;
  box-shadow: 0 6px 24px rgba(88,204,2,0.30), 0 2px 8px rgba(88,204,2,0.15);
  transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1); padding: 0;
}
.login-page__btn::after { border: none; }
.login-page__btn:active { transform: scale(0.96); opacity: 0.9; }
.login-page__btn[disabled] {
  background: rgba(88,204,2,0.6); box-shadow: none;
}

.login-page__divider {
  display: flex; align-items: center; gap: 16rpx;
  width: 100%; margin: 24rpx 0;
}

.login-page__divider-line {
  flex: 1; height: 1rpx; background: #E8E8E8;
}

.login-page__divider-text {
  font-size: 24rpx; color: #A0A0A0; flex-shrink: 0; font-weight: 500;
}

.login-page__join {
  display: flex; gap: 12rpx; width: 100%;
}

.login-page__invite-input {
  flex: 1; height: 56rpx; line-height: 56rpx;
  background: #FFFFFF; border-radius: 100rpx;
  padding: 0 24rpx; font-size: 30rpx; color: #3C3C3C;
  text-align: center; letter-spacing: 8rpx;
  border: 2rpx solid #E8E8E8;
}
.login-page__invite-input::placeholder {
  font-size: 24rpx; color: #CFCFCF; letter-spacing: 2rpx;
}

.login-page__join-btn {
  width: 180rpx; height: 56rpx; line-height: 56rpx;
  background: linear-gradient(135deg, #1498D4, #1CB0F6);
  color: #FFFFFF;
  border-radius: 100rpx; font-size: 26rpx; font-weight: 700;
  border: none; padding: 0; flex-shrink: 0;
  box-shadow: 0 4px 16px rgba(28,176,246,0.25);
}
.login-page__join-btn::after { border: none; }
.login-page__join-btn:active { transform: scale(0.96); opacity: 0.85; }
.login-page__join-btn[disabled] {
  background: #CFCFCF; color: #A0A0A0;
}

.login-page__hint {
  font-size: 24rpx; color: #CFCFCF;
  margin-top: 10rpx; text-align: center;
}
