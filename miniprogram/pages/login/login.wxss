/* iOS Login */
.login-page {
  min-height: 100vh;
  background: linear-gradient(180deg, rgba(0,122,255,0.06) 0%, #F2F2F7 35%);
  display: flex; flex-direction: column; align-items: center;
  padding: 80rpx 32rpx 40rpx;
  position: relative; overflow: hidden;
}

/* Ambient light orbs */
.login-page::before {
  content: ''; position: absolute;
  top: -100rpx; right: -60rpx;
  width: 300rpx; height: 300rpx; border-radius: 50%;
  background: radial-gradient(circle, rgba(0,122,255,0.08) 0%, transparent 70%);
  pointer-events: none;
}
.login-page::after {
  content: ''; position: absolute;
  bottom: 200rpx; left: -80rpx;
  width: 240rpx; height: 240rpx; border-radius: 50%;
  background: radial-gradient(circle, rgba(52,199,89,0.06) 0%, transparent 70%);
  pointer-events: none;
}

/* Hero */
.login-page__hero {
  display: flex; flex-direction: column; align-items: center;
  margin-bottom: 48rpx; position: relative; z-index: 1;
}

.login-page__logo-wrap {
  width: 160rpx; height: 160rpx; border-radius: 50%;
  background: rgba(255,255,255,0.8);
  box-shadow: 0 8px 32px rgba(0,0,0,0.08);
  display: flex; align-items: center; justify-content: center;
  margin-bottom: 24rpx;
  animation: logo-float 4s ease-in-out infinite;
}

@keyframes logo-float {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-10rpx); }
}

.login-page__logo { font-size: 80rpx; line-height: 1; }

.login-page__app-name {
  font-size: 34rpx; font-weight: 600;
  color: #1d1d1f;
  margin-bottom: 4rpx; letter-spacing: 4rpx;
}

.login-page__slogan {
  font-size: 24rpx; color: #C7C7CC; letter-spacing: 2rpx;
}

/* Features */
.login-page__features {
  display: flex; flex-direction: column; gap: 12rpx;
  width: 100%; margin-bottom: 48rpx; position: relative; z-index: 1;
}

.login-page__feature {
  display: flex; align-items: center; gap: 16rpx;
  padding: 16rpx 16rpx;
  background: #FFFFFF;
  border-radius: 16rpx;
  box-shadow: 0 2px 16px rgba(0,0,0,0.04);
}
.login-page__feature:active { transform: scale(0.975); }

.login-page__feature-icon-wrap {
  width: 64rpx; height: 64rpx; border-radius: 50%;
  display: flex; align-items: center; justify-content: center; flex-shrink: 0;
}
.login-page__feature-icon-wrap--blue  { background: rgba(0,122,255,0.1); }
.login-page__feature-icon-wrap--orange { background: rgba(255,149,0,0.1); }
.login-page__feature-icon-wrap--green { background: rgba(52,199,89,0.1); }

.login-page__feature-icon { font-size: 32rpx; line-height: 1; }

.login-page__feature-info { display: flex; flex-direction: column; gap: 2rpx; flex: 1; }

.login-page__feature-title {
  font-size: 28rpx; color: #1d1d1f; font-weight: 600;
}
.login-page__feature-sub {
  font-size: 24rpx; color: #C7C7CC;
}

/* Button */
.login-page__btn {
  width: 100%; height: 52rpx; line-height: 52rpx;
  background: #07C160; color: #FFFFFF;
  border-radius: 100rpx; font-size: 28rpx; font-weight: 600;
  border: none; box-shadow: 0 4px 16px rgba(7,193,96,0.25);
  transition: all 0.2s ease; position: relative; z-index: 1;
}
.login-page__btn::after { border: none; }
.login-page__btn:active { transform: scale(0.96); opacity: 0.9; }
