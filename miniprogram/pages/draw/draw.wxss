/* iOS Draw */
.draw-page { min-height: 100vh; background: #F2F2F7; }

/* Header */
.draw-page__header {
  display: flex; align-items: center; justify-content: space-between;
  padding: 8rpx 32rpx;
  background: #FFFFFF;
  position: sticky; top: 0; z-index: 99;
}

.draw-page__title {
  font-size: 34rpx; font-weight: 600;
  color: #1d1d1f; letter-spacing: -0.3rpx;
}

.draw-page__points {
  display: flex; justify-content: center; padding: 24rpx 0;
}

.draw-page__cards { padding: 0 32rpx; }

.draw-page__section { padding: 24rpx 32rpx; }

.draw-page__section-title {
  font-size: 20rpx; font-weight: 600;
  color: #8E8E93; margin-bottom: 12rpx; display: block;
}

.draw-page__record {
  display: flex; align-items: center; gap: 12rpx;
  padding: 12rpx;
  background: #FFFFFF;
  border-radius: 12rpx; margin-bottom: 8rpx;
  box-shadow: 0 2px 16px rgba(0,0,0,0.04);
}
.draw-page__record:active { transform: scale(0.98); }

.draw-page__record-icon { font-size: 24rpx; }
.draw-page__record-info { flex: 1; display: flex; flex-direction: column; }

.draw-page__record-name {
  font-size: 26rpx; font-weight: 500; color: #1d1d1f;
}

.draw-page__record-cost { font-size: 22rpx; color: #8E8E93; }

.draw-page__record-time { font-size: 22rpx; color: #C7C7CC; }

.draw-page__parent-link {
  text-align: center; padding: 16rpx;
  font-size: 22rpx; color: #C7C7CC;
}
