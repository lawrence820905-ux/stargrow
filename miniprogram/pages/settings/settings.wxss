/* iOS Settings — classic grouped list */
.settings-page { min-height: 100vh; background: #F2F2F7; }

/* Header */
.settings-page__header {
  padding: 8rpx 32rpx;
  background: #FFFFFF;
  position: sticky; top: 0; z-index: 99;
}

.settings-page__title {
  font-size: 34rpx; font-weight: 600;
  color: #1d1d1f; letter-spacing: -0.3rpx;
}

/* Section */
.settings-page__section { padding: 12rpx 32rpx; }

.settings-page__section-label {
  font-size: 24rpx; color: #8E8E93;
  padding: 0 8rpx 8rpx;
  display: block; font-weight: 500;
}

.settings-page__card {
  background: #FFFFFF;
  border-radius: 16rpx; overflow: hidden; box-shadow: 0 2px 16px rgba(0,0,0,0.04);
}

.settings-page__row {
  display: flex; align-items: center;
  padding: 16rpx 16rpx;
  border-bottom: 0.5px solid #C6C6C8;
  transition: all 0.2s ease;
}
.settings-page__row:last-child { border-bottom: none; }
.settings-page__row:active { background: rgba(0,0,0,0.04); }

.settings-page__row-icon { font-size: 28rpx; margin-right: 12rpx; }

.settings-page__row-text {
  flex: 1; font-size: 28rpx; color: #1d1d1f;
}

.settings-page__row-arrow {
  font-size: 28rpx; color: #C7C7CC;
}

/* Feedback Modal */
.settings-page__overlay {
  position: fixed; top: 0; left: 0; right: 0; bottom: 0;
  z-index: 200;
  display: flex; align-items: center; justify-content: center;
}
.settings-page__overlay-bg {
  position: absolute; top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.4);
}

.settings-page__feedback-modal {
  position: relative; z-index: 1;
  width: 600rpx;
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 32rpx;
  animation: settings-fade-in 0.25s ease forwards;
}
@keyframes settings-fade-in { from { opacity: 0; transform: scale(0.95); } to { opacity: 1; transform: scale(1); } }

.settings-page__feedback-title {
  font-size: 30rpx; font-weight: 700; text-align: center;
  margin-bottom: 24rpx; display: block; color: #1d1d1f;
}

.settings-page__feedback-textarea {
  background: #F2F2F7; border-radius: 12rpx;
  padding: 16rpx; font-size: 28rpx; color: #1d1d1f;
  min-height: 200rpx; width: 100%; box-sizing: border-box;
}

.settings-page__feedback-count {
  text-align: right; font-size: 22rpx; color: #C7C7CC;
  margin-top: 8rpx; display: block;
}

.settings-page__feedback-btns { display: flex; gap: 12rpx; margin-top: 24rpx; }

.settings-page__feedback-cancel {
  flex: 1; height: 48rpx; line-height: 48rpx;
  background: #F2F2F7; color: #8E8E93;
  border-radius: 12rpx; font-size: 28rpx; border: none;
}
.settings-page__feedback-cancel::after { border: none; }

.settings-page__feedback-submit {
  flex: 1; height: 48rpx; line-height: 48rpx;
  background: #007AFF; color: #FFFFFF;
  border-radius: 12rpx; font-size: 28rpx; font-weight: 600; border: none;
}
.settings-page__feedback-submit::after { border: none; }
