/* Settings — 改进版：更清晰的条目显示 */
.settings-page { min-height: 100vh; background: var(--color-background); padding-bottom: 200rpx; }

/* Section */
.settings-page__section { padding: 20rpx 32rpx; }

.settings-page__section-label {
  font-size: 24rpx; font-weight: 600;
  color: #8E8E93;
  padding: 0 8rpx 12rpx;
  display: block;
  letter-spacing: 1rpx;
}

.settings-page__card {
  background: #FFFFFF;
  border-radius: 20rpx; overflow: hidden;
  box-shadow: 0 4px 0 rgba(0,0,0,0.06), 0 2px 8px rgba(0,0,0,0.04);
}

.settings-page__row {
  display: flex; align-items: center;
  padding: 20rpx 20rpx;
  border-bottom: 0.5px solid #E8E8E8;
  transition: all 0.15s ease;
  min-height: 88rpx;
}
.settings-page__row:last-child { border-bottom: none; }
.settings-page__row:active { background: rgba(0,0,0,0.04); transform: scale(0.99); }

.settings-page__row-icon {
  font-size: 36rpx; margin-right: 16rpx;
  width: 48rpx; text-align: center; flex-shrink: 0;
}

.settings-page__row-body {
  flex: 1; min-width: 0;
  display: flex; flex-direction: column;
}

.settings-page__row-text {
  font-size: 30rpx; font-weight: 600;
  color: #3C3C3C; line-height: 1.4;
}

.settings-page__row-sub {
  font-size: 24rpx; color: #A0A0A0;
  margin-top: 2rpx; line-height: 1.3;
}

.settings-page__row-arrow {
  font-size: 32rpx; color: #CFCFCF;
  margin-left: 12rpx; flex-shrink: 0;
}

/* Family management */
.settings-page__row--invite {
  display: flex; align-items: center; justify-content: space-between;
}

.settings-page__row-left {
  display: flex; align-items: center;
  flex: 1; min-width: 0;
}

.settings-page__invite-code {
  display: flex; align-items: center; gap: 8rpx;
  padding: 8rpx 16rpx;
  background: #F5FAF0;
  border-radius: 12rpx;
  flex-shrink: 0;
}

.settings-page__invite-code:active { opacity: 0.6; }

.settings-page__invite-code-text {
  font-size: 30rpx; font-weight: 700; color: #58CC02; letter-spacing: 4rpx;
}

.settings-page__invite-copy {
  font-size: 24rpx; color: #58CC02; font-weight: 600;
}

.settings-page__row--members {
  border-bottom: 0.5px solid #E8E8E8;
}

/* Join Family */
.settings-page__row--join {
  background: #FFFDF5;
}

.settings-page__join-bar {
  display: flex; flex-direction: column; gap: 12rpx;
  padding: 0 20rpx 20rpx;
}

.settings-page__join-input {
  width: 100%; height: 56rpx; line-height: 56rpx;
  background: #FFFFFF; border-radius: 100rpx;
  padding: 0 24rpx; font-size: 28rpx; color: #3C3C3C;
  text-align: center; letter-spacing: 8rpx;
  border: 2rpx solid #DDD;
  box-sizing: border-box;
}
.settings-page__join-input::placeholder {
  font-size: 24rpx; color: #B0B0B0; letter-spacing: 2rpx;
}

.settings-page__join-btn {
  width: 100%; height: 48rpx; line-height: 48rpx;
  background: linear-gradient(135deg, #1498D4, #1CB0F6);
  color: #FFFFFF;
  border-radius: 100rpx; font-size: 24rpx; font-weight: 700;
  border: none; padding: 0;
  box-shadow: 0 4px 16px rgba(28,176,246,0.25);
}
.settings-page__join-btn::after { border: none; }
.settings-page__join-btn[disabled] {
  background: #CFCFCF; color: #A0A0A0; box-shadow: none;
}

.settings-page__member-list {
  padding: 0 20rpx 8rpx;
}

.settings-page__member {
  display: flex; align-items: center; gap: 12rpx;
  padding: 14rpx 0;
}

.settings-page__member-avatar {
  font-size: 36rpx; width: 52rpx; height: 52rpx;
  border-radius: 50%; background: #F5F5F5;
  display: flex; align-items: center; justify-content: center;
  text-align: center; line-height: 52rpx;
}

.settings-page__member-name {
  flex: 1; font-size: 28rpx; font-weight: 500; color: #3C3C3C;
}

.settings-page__member-id {
  font-size: 24rpx; color: #A0A0A0;
}

/* Feedback Modal */
.settings-page__overlay {
  position: fixed; top: 0; left: 0; right: 0; bottom: 0;
  z-index: 200;
  display: flex; align-items: center; justify-content: center;
}
.settings-page__overlay-bg {
  position: absolute; top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.4);
}
.settings-page__feedback-modal {
  position: relative; z-index: 1;
  width: 600rpx;
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 32rpx;
  animation: settings-fade-in 0.25s ease forwards;
}
@keyframes settings-fade-in { from { opacity: 0; transform: scale(0.95); } to { opacity: 1; transform: scale(1); } }

.settings-page__feedback-title {
  font-size: 32rpx; font-weight: 700; text-align: center;
  margin-bottom: 20rpx; display: block; color: #3C3C3C;
}

.settings-page__feedback-types { display: flex; gap: 12rpx; margin-bottom: 20rpx; }
.settings-page__feedback-type {
  flex: 1; padding: 16rpx 0; border-radius: 14rpx;
  background: #F5F5F5; text-align: center;
  font-size: 24rpx; color: #8E8E93; font-weight: 600;
}
.settings-page__feedback-type--active {
  background: #EEF8FF; color: #1CB0F6;
}

.settings-page__feedback-textarea {
  background: #F5F5F5; border-radius: 16rpx;
  padding: 16rpx; font-size: 28rpx; color: #3C3C3C;
  min-height: 160rpx; width: 100%; box-sizing: border-box;
}

.settings-page__feedback-btns { display: flex; gap: 12rpx; margin-top: 24rpx; }
.settings-page__feedback-cancel {
  flex: 1; padding: 20rpx 0; border-radius: 14rpx;
  background: #F5F5F5; font-size: 28rpx; color: #8E8E93;
  font-weight: 600; text-align: center;
}
.settings-page__feedback-submit {
  flex: 1; padding: 20rpx 0; border-radius: 14rpx;
  background: linear-gradient(135deg, #46A800, #58CC02);
  font-size: 28rpx; color: #FFFFFF; font-weight: 700; text-align: center;
}
