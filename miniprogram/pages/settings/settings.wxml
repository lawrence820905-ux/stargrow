<view class="settings-page">
  <nav-bar title="设置" />

  <!-- Family Management -->
  <view class="settings-page__section">
    <text class="settings-page__section-label">家庭管理</text>
    <view class="settings-page__card">
      <view class="settings-page__row settings-page__row--invite">
        <view class="settings-page__row-left">
          <text class="settings-page__row-icon">🔑</text>
          <view class="settings-page__row-body">
            <text class="settings-page__row-text">邀请码</text>
            <text class="settings-page__row-sub">分享给家人，加入同一个家庭</text>
          </view>
        </view>
        <view class="settings-page__invite-code" bindtap="onCopyInvite">
          <text class="settings-page__invite-code-text">{{inviteCode || '获取中...'}}</text>
          <text class="settings-page__invite-copy">复制</text>
        </view>
      </view>
      <view class="settings-page__row settings-page__row--members">
        <view class="settings-page__row-left">
          <text class="settings-page__row-icon">👥</text>
          <text class="settings-page__row-text">家庭成员（{{memberCount}}人）</text>
        </view>
      </view>
      <view class="settings-page__member-list">
        <view class="settings-page__member" wx:for="{{members}}" wx:key="index">
          <text class="settings-page__member-avatar">👤</text>
          <view class="settings-page__member-info">
            <text class="settings-page__member-name">{{item.nickname || '家长' + (index + 1)}}</text>
            <text class="settings-page__member-id">ID: ***{{item.openid || item}}</text>
          </view>
        </view>
      </view>
      <view class="settings-page__row" bindtap="onGoChildManage">
        <text class="settings-page__row-icon">👶</text>
        <view class="settings-page__row-body">
          <text class="settings-page__row-text">孩子管理</text>
          <text class="settings-page__row-sub">添加、编辑或删除孩子信息</text>
        </view>
        <text class="settings-page__row-arrow">›</text>
      </view>
    </view>
  </view>

  <!-- Points Mall Management -->
  <view class="settings-page__section">
    <text class="settings-page__section-label">积分商城管理</text>
    <view class="settings-page__card">
      <view class="settings-page__row" bindtap="onGoShopConfig">
        <text class="settings-page__row-icon">🏪</text>
        <view class="settings-page__row-body">
          <text class="settings-page__row-text">商品管理</text>
          <text class="settings-page__row-sub">创建和管理积分兑换商品</text>
        </view>
        <text class="settings-page__row-arrow">›</text>
      </view>
      <view class="settings-page__row" bindtap="onGoDrawConfig">
        <text class="settings-page__row-icon">📦</text>
        <view class="settings-page__row-body">
          <text class="settings-page__row-text">宝箱配置</text>
          <text class="settings-page__row-sub">配置抽奖宝箱的奖励池和概率</text>
        </view>
        <text class="settings-page__row-arrow">›</text>
      </view>
      <view class="settings-page__row" bindtap="onGoExchangeLog">
        <text class="settings-page__row-icon">🛒</text>
        <view class="settings-page__row-body">
          <text class="settings-page__row-text">兑换记录</text>
          <text class="settings-page__row-sub">查看孩子的积分兑换历史</text>
        </view>
        <text class="settings-page__row-arrow">›</text>
      </view>
    </view>
  </view>

  <!-- Data -->
  <view class="settings-page__section">
    <text class="settings-page__section-label">数据</text>
    <view class="settings-page__card">
      <view class="settings-page__row" bindtap="onGoStats">
        <text class="settings-page__row-icon">📊</text>
        <view class="settings-page__row-body">
          <text class="settings-page__row-text">数据统计</text>
          <text class="settings-page__row-sub">查看任务完成率和积分趋势</text>
        </view>
        <text class="settings-page__row-arrow">›</text>
      </view>
      <view class="settings-page__row" bindtap="onGoAchievementConfig">
        <text class="settings-page__row-icon">🏅</text>
        <view class="settings-page__row-body">
          <text class="settings-page__row-text">成就墙设置</text>
          <text class="settings-page__row-sub">配置成就徽章和达成条件</text>
        </view>
        <text class="settings-page__row-arrow">›</text>
      </view>
      <view class="settings-page__row" bindtap="onGoPointLog">
        <text class="settings-page__row-icon">📋</text>
        <view class="settings-page__row-body">
          <text class="settings-page__row-text">积分流水</text>
          <text class="settings-page__row-sub">查看所有积分变动记录</text>
        </view>
        <text class="settings-page__row-arrow">›</text>
      </view>
    </view>
  </view>

  <!-- Other -->
  <view class="settings-page__section">
    <text class="settings-page__section-label">其他</text>
    <view class="settings-page__card">
      <view class="settings-page__row">
        <text class="settings-page__row-icon">ℹ️</text>
        <text class="settings-page__row-text">关于成长派克 v1.0</text>
      </view>
      <view class="settings-page__row" bindtap="onShowFeedback">
        <text class="settings-page__row-icon">💬</text>
        <view class="settings-page__row-body">
          <text class="settings-page__row-text">意见反馈</text>
          <text class="settings-page__row-sub">告诉我们你的想法和问题</text>
        </view>
        <text class="settings-page__row-arrow">›</text>
      </view>
    </view>
  </view>

  <!-- Feedback Modal -->
  <view class="settings-page__overlay" wx:if="{{showFeedback}}">
    <view class="settings-page__overlay-bg" bindtap="onCloseFeedback"></view>
    <view class="settings-page__feedback-modal">
      <text class="settings-page__feedback-title">意见反馈</text>

      <!-- Category tabs -->
      <view class="settings-page__feedback-types">
        <view
          class="settings-page__feedback-type {{feedbackType === 'bug' ? 'settings-page__feedback-type--active' : ''}}"
          bindtap="onSelectFeedbackType" data-type="bug"
        >
          <text>🐛 功能异常</text>
        </view>
        <view
          class="settings-page__feedback-type {{feedbackType === 'suggest' ? 'settings-page__feedback-type--active' : ''}}"
          bindtap="onSelectFeedbackType" data-type="suggest"
        >
          <text>💡 产品建议</text>
        </view>
      </view>

      <textarea
        class="settings-page__feedback-textarea"
        placeholder="请描述你遇到的问题或建议..."
        value="{{feedbackText}}"
        bindinput="onFeedbackInput"
      />
      <view class="settings-page__feedback-btns">
        <view class="settings-page__feedback-cancel" bindtap="onCloseFeedback">取消</view>
        <view class="settings-page__feedback-submit" bindtap="onSubmitFeedback">提交</view>
      </view>
    </view>
  </view>

  <view class="safe-area-bottom" style="height: 120rpx;"></view>
</view>
