<view class="settings-page">
  <view class="settings-page__header">
    <text class="settings-page__title">设置</text>
  </view>

  <!-- Child Management -->
  <view class="settings-page__section">
    <text class="settings-page__section-label">孩子管理</text>
    <view class="settings-page__card">
      <view class="settings-page__row" bindtap="onGoChildManage">
        <text class="settings-page__row-icon">👶</text>
        <text class="settings-page__row-text">孩子管理</text>
        <text class="settings-page__row-arrow">›</text>
      </view>
    </view>
  </view>

  <!-- Draw Config -->
  <view class="settings-page__section">
    <text class="settings-page__section-label">抽奖配置</text>
    <view class="settings-page__card">
      <view class="settings-page__row" bindtap="onGoDrawConfig">
        <text class="settings-page__row-icon">🎰</text>
        <text class="settings-page__row-text">抽奖配置</text>
        <text class="settings-page__row-arrow">›</text>
      </view>
    </view>
  </view>

  <!-- Data -->
  <view class="settings-page__section">
    <text class="settings-page__section-label">数据</text>
    <view class="settings-page__card">
      <view class="settings-page__row" bindtap="onGoStats">
        <text class="settings-page__row-icon">📊</text>
        <text class="settings-page__row-text">数据统计</text>
        <text class="settings-page__row-arrow">›</text>
      </view>
      <view class="settings-page__row" bindtap="onGoAchievementConfig">
        <text class="settings-page__row-icon">🏅</text>
        <text class="settings-page__row-text">成就墙设置</text>
        <text class="settings-page__row-arrow">›</text>
      </view>
      <view class="settings-page__row" bindtap="onGoPointLog">
        <text class="settings-page__row-icon">📋</text>
        <text class="settings-page__row-text">积分流水</text>
        <text class="settings-page__row-arrow">›</text>
      </view>
    </view>
  </view>

  <!-- Other -->
  <view class="settings-page__section">
    <text class="settings-page__section-label">其他</text>
    <view class="settings-page__card">
      <view class="settings-page__row">
        <text class="settings-page__row-icon">ℹ️</text>
        <text class="settings-page__row-text">关于成长之星 v1.0</text>
      </view>
      <view class="settings-page__row" bindtap="onShowFeedback">
        <text class="settings-page__row-icon">💬</text>
        <text class="settings-page__row-text">优化建议</text>
        <text class="settings-page__row-arrow">›</text>
      </view>
    </view>
  </view>

  <!-- Feedback Modal -->
  <view class="settings-page__overlay" wx:if="{{showFeedback}}">
    <view class="settings-page__overlay-bg" bindtap="onCloseFeedback"></view>
    <view class="settings-page__feedback-modal">
      <text class="settings-page__feedback-title">优化建议</text>
      <textarea
        class="settings-page__feedback-textarea"
        placeholder="请描述您遇到的问题或改进建议..."
        value="{{feedbackText}}"
        bindinput="onFeedbackInput"
        maxlength="500"
      />
      <text class="settings-page__feedback-count">{{feedbackText.length || 0}}/500</text>
      <view class="settings-page__feedback-btns">
        <button class="settings-page__feedback-cancel" bindtap="onCloseFeedback">取消</button>
        <button class="settings-page__feedback-submit" bindtap="onSubmitFeedback">提交</button>
      </view>
    </view>
  </view>

  <view class="safe-area-bottom"></view>
</view>
