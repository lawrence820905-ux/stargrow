/* Duolingo ABC Stats 鈥?Visual Charts */
.stats-page { min-height: 100vh; background: var(--color-background); padding-bottom: 60rpx; }

.stats-page__section { padding: 0 32rpx 16rpx; }

.stats-page__section-title {
  font-size: 26rpx; font-weight: 700; margin-bottom: 12rpx;
  display: block; color: #3C3C3C;
  border-left: 6rpx solid #58CC02; padding-left: 12rpx;
}

.stats-page__card {
  background: #FFFFFF;
  border-radius: 24rpx; overflow: hidden;
  box-shadow: 0 4px 0 rgba(0,0,0,0.06), 0 2px 8px rgba(0,0,0,0.04);
  padding: 16rpx;
}

/* Overview Cards Grid */
.stats-page__overview-grid {
  display: flex; flex-wrap: wrap;
}

.stats-page__overview-card {
  width: 50%; padding: 6rpx; box-sizing: border-box;
  display: flex; flex-direction: column;
}
.stats-page__overview-card-inner {
  background: #FFFFFF;
  border-radius: 24rpx; padding: 24rpx 16rpx;
  display: flex; flex-direction: column; align-items: center; gap: 6rpx;
  box-shadow: 0 4px 0 rgba(0,0,0,0.06), 0 2px 8px rgba(0,0,0,0.04);
}

.stats-page__overview-icon { font-size: 40rpx; }

.stats-page__overview-value {
  font-size: 48rpx; font-weight: 800; color: #3C3C3C;
  max-width: 100%; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
}

.stats-page__overview-unit {
  font-size: 24rpx; font-weight: 400; color: #A0A0A0;
}

.stats-page__overview-label {
  font-size: 24rpx; color: #A0A0A0; font-weight: 600;
}

/* Weekly Chart */
.stats-page__chart { padding: 8rpx 0; }

.stats-page__bars {
  display: flex; align-items: flex-end; justify-content: space-around;
  height: 220rpx; padding-top: 20rpx;
}

.stats-page__bar-col {
  display: flex; flex-direction: column; align-items: center;
  flex: 1;
}

.stats-page__bar-wrapper {
  flex: 1; display: flex; align-items: flex-end;
  width: 100%; justify-content: center;
}

.stats-page__bar {
  width: 40rpx; min-height: 8rpx;
  background: linear-gradient(0deg, #1CB0F6, #58CC02);
  border-radius: 10rpx 10rpx 0 0;
  display: flex; align-items: flex-start; justify-content: center;
  box-shadow: 0 -2px 8px rgba(88,204,2,0.15);
  transition: height 0.5s cubic-bezier(0.34, 1.56, 0.64, 1);
}

.stats-page__bar-val {
  font-size: 24rpx; font-weight: 800; color: #58CC02;
  margin-top: -22rpx;
}

.stats-page__bar-label {
  font-size: 24rpx; color: #CFCFCF; margin-top: 8rpx;
  white-space: nowrap; font-weight: 600;
}

.stats-page__chart-legend {
  display: flex; justify-content: center; gap: 24rpx;
  padding-top: 8rpx; border-top: 1px solid #E8E8E8;
}

.stats-page__legend-item {
  display: flex; align-items: center; gap: 6rpx;
  font-size: 24rpx; color: #A0A0A0; font-weight: 500;
}

.stats-page__legend-dot {
  width: 16rpx; height: 16rpx; border-radius: 50%;
}
.stats-page__legend-dot--blue { background: #1CB0F6; box-shadow: 0 0 6px rgba(28,176,246,0.30); }
.stats-page__legend-dot--orange { background: #FF9600; box-shadow: 0 0 6px rgba(255,150,0,0.30); }

/* Category Breakdown */
.stats-page__cat-row {
  display: flex; align-items: center; gap: 10rpx;
  padding: 14rpx 0;
  border-bottom: 1px solid #F5F5F5;
}
.stats-page__cat-row:last-child { border-bottom: none; }

.stats-page__cat-icon { font-size: 28rpx; flex-shrink: 0; }

.stats-page__cat-name {
  font-size: 26rpx; font-weight: 600; color: #3C3C3C;
  width: 72rpx; flex-shrink: 0;
}

.stats-page__cat-val {
  font-size: 24rpx; font-weight: 700; color: #A0A0A0;
  width: 64rpx; text-align: right; flex-shrink: 0;
}

.stats-page__cat-bar {
  flex: 1; height: 20rpx; background: #F5F5F5;
  border-radius: 10rpx; overflow: hidden;
}

.stats-page__cat-fill {
  height: 100%; border-radius: 10rpx;
  box-shadow: 0 0 6px rgba(0,0,0,0.08);
  transition: width 0.6s cubic-bezier(0.34, 1.56, 0.64, 1);
}
.stats-page__cat-fill--blue { background: linear-gradient(90deg, #1498D4, #1CB0F6); }
.stats-page__cat-fill--green { background: linear-gradient(90deg, #5AB866, #58CC02); }
.stats-page__cat-fill--orange { background: linear-gradient(90deg, #E08800, #FF9600); }

/* Superpower Card */
.stats-page__superpower-card {
  display: flex; align-items: center; gap: 20rpx; padding: 32rpx 24rpx;
}

.stats-page__superpower-icon { font-size: 64rpx; flex-shrink: 0; }

.stats-page__superpower-info { flex: 1; display: flex; flex-direction: column; gap: 6rpx; }

.stats-page__superpower-title {
  font-size: 30rpx; font-weight: 800; color: #3C3C3C;
}

.stats-page__superpower-message {
  font-size: 24rpx; color: #8E8E93; line-height: 1.5;
}

/* Family Goal */
.stats-page__goal-title {
  font-size: 28rpx; font-weight: 700; color: #3C3C3C;
  display: block; margin-bottom: 4rpx; text-align: center;
}
.stats-page__goal-reward {
  font-size: 24rpx; color: #FF9600; font-weight: 600;
  display: block; text-align: center; margin-bottom: 12rpx;
}
.stats-page__goal-bar-wrap {
  width: 100%; height: 20rpx; background: #F5F5F5;
  border-radius: 10rpx; overflow: hidden; margin-bottom: 8rpx;
}
.stats-page__goal-bar {
  height: 100%; border-radius: 10rpx;
  background: linear-gradient(90deg, #FF9500, #FF6B00);
  transition: width 0.6s cubic-bezier(0.34, 1.56, 0.64, 1);
}
.stats-page__goal-progress {
  display: flex; justify-content: space-between;
  font-size: 24rpx; color: #8E8E93; font-weight: 600;
}
.stats-page__goal-percent { color: #FF9500; }
.stats-page__goal-completed {
  margin-top: 12rpx; padding: 12rpx;
  background: #FFF9E6; border-radius: 12rpx; text-align: center;
}
.stats-page__goal-completed text {
  font-size: 26rpx; font-weight: 700; color: #FF9500;
}
.stats-page__goal-hint {
  font-size: 24rpx; color: #A0A0A0; text-align: center;
  display: block; margin-bottom: 12rpx;
}
.stats-page__goal-suggestions {
  display: flex; flex-direction: column; gap: 8rpx;
}
.stats-page__goal-suggestion {
  display: flex; align-items: center; justify-content: space-between;
  padding: 16rpx 20rpx; border-radius: 16rpx;
  background: #FFF8F0; border: 2rpx solid #FFE8C0;
}
.stats-page__goal-suggestion:active { background: #FFF0E0; }
.stats-page__goal-sug-text {
  font-size: 24rpx; color: #8E7300; font-weight: 500; flex: 1;
}
.stats-page__goal-sug-btn {
  font-size: 22rpx; color: #FF9500; font-weight: 700;
  padding: 4rpx 12rpx; border-radius: 8rpx;
  background: rgba(255,149,0,0.1);
}

/* Family Garden */
.stats-page__garden-hint {
  font-size: 24rpx; color: #A0A0A0; text-align: center;
  display: block; padding-bottom: 16rpx; border-bottom: 1px solid #F5F5F5;
  margin-bottom: 16rpx;
}

.stats-page__garden-grid {
  display: flex; gap: 16rpx; flex-wrap: wrap;
}

.stats-page__garden-plant {
  flex: 1; min-width: 140rpx;
  display: flex; flex-direction: column; align-items: center; gap: 6rpx;
  padding: 24rpx 16rpx; border-radius: 20rpx;
  background: #F9F9FB; border: 2rpx solid transparent;
  transition: all 0.2s ease;
}

.stats-page__garden-plant--active {
  background: #F0FFE8; border-color: #58CC02;
}

.stats-page__garden-emoji { font-size: 56rpx; }

.stats-page__garden-name {
  font-size: 26rpx; font-weight: 700; color: #3C3C3C;
}

.stats-page__garden-level {
  font-size: 22rpx; color: #8E8E93; font-weight: 500;
}

.stats-page__garden-week {
  font-size: 22rpx; color: #A0A0A0;
}

/* Cheer Button */
.stats-page__cheer-btn {
  margin-top: 8rpx; padding: 8rpx 24rpx;
  background: linear-gradient(135deg, #FF9500, #FF6B00);
  color: #FFFFFF; border-radius: 100rpx;
  font-size: 24rpx; font-weight: 600;
  box-shadow: 0 2px 8px rgba(255,149,0,0.2);
}
.stats-page__cheer-btn:active { opacity: 0.7; transform: scale(0.95); }

/* Weekly Comparison */
.stats-page__comp-row {
  display: flex; align-items: center; gap: 12rpx;
  padding: 16rpx 8rpx;
  border-bottom: 1px solid #F5F5F5;
}
.stats-page__comp-row:last-child { border-bottom: none; }

.stats-page__comp-label {
  font-size: 24rpx; color: #8E8E93; font-weight: 600;
  width: 120rpx; flex-shrink: 0;
}

.stats-page__comp-val {
  font-size: 26rpx; font-weight: 700; color: #3C3C3C;
  flex: 1;
}

.stats-page__comp-change {
  font-size: 24rpx; font-weight: 700;
  flex-shrink: 0;
}

.stats-page__comp-trend {
  font-size: 24rpx; font-weight: 600;
  flex-shrink: 0;
}
.color-green { color: #58CC02; }
.color-red { color: #FF4B4B; }
.color-gray { color: #A0A0A0; }

.settings-page__member-info { flex: 1; min-width: 0; }
