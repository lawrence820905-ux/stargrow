/* iOS Stats — Visual Charts */
.stats-page { min-height: 100vh; background: #F2F2F7; padding-bottom: 60rpx; }

.stats-page__section { padding: 0 32rpx 16rpx; }

.stats-page__section-title {
  font-size: 24rpx; font-weight: 600; margin-bottom: 8rpx;
  display: block; color: #1d1d1f;
}

.stats-page__card {
  background: #FFFFFF;
  border-radius: 16rpx; overflow: hidden;
  box-shadow: 0 2px 16px rgba(0,0,0,0.04);
  padding: 16rpx;
}

/* Overview Cards Grid */
.stats-page__overview-grid {
  display: flex; flex-wrap: wrap; gap: 12rpx;
}

.stats-page__overview-card {
  width: calc(50% - 6rpx);
  background: #FFFFFF;
  border-radius: 16rpx; padding: 20rpx 16rpx;
  display: flex; flex-direction: column; align-items: center; gap: 6rpx;
  box-shadow: 0 2px 16px rgba(0,0,0,0.04);
  box-sizing: border-box;
}

.stats-page__overview-icon { font-size: 36rpx; }

.stats-page__overview-value {
  font-size: 40rpx; font-weight: 700; color: #1d1d1f;
}

.stats-page__overview-unit {
  font-size: 24rpx; font-weight: 400; color: #8E8E93;
}

.stats-page__overview-label {
  font-size: 22rpx; color: #8E8E93;
}

/* Weekly Chart */
.stats-page__chart { padding: 8rpx 0; }

.stats-page__bars {
  display: flex; align-items: flex-end; justify-content: space-around;
  height: 220rpx; padding-top: 20rpx;
}

.stats-page__bar-col {
  display: flex; flex-direction: column; align-items: center;
  flex: 1;
}

.stats-page__bar-wrapper {
  flex: 1; display: flex; align-items: flex-end;
  width: 100%; justify-content: center;
}

.stats-page__bar {
  width: 36rpx; min-height: 8rpx;
  background: linear-gradient(180deg, #007AFF, #5AC8FA);
  border-radius: 8rpx 8rpx 0 0;
  display: flex; align-items: flex-start; justify-content: center;
  transition: height 0.5s cubic-bezier(0.34, 1.56, 0.64, 1);
}

.stats-page__bar-val {
  font-size: 18rpx; font-weight: 600; color: #007AFF;
  margin-top: -22rpx;
}

.stats-page__bar-label {
  font-size: 18rpx; color: #C7C7CC; margin-top: 8rpx;
  white-space: nowrap;
}

.stats-page__chart-legend {
  display: flex; justify-content: center; gap: 24rpx;
  padding-top: 8rpx; border-top: 0.5px solid #C6C6C8;
}

.stats-page__legend-item {
  display: flex; align-items: center; gap: 6rpx;
  font-size: 22rpx; color: #8E8E93;
}

.stats-page__legend-dot {
  width: 16rpx; height: 16rpx; border-radius: 50%;
}
.stats-page__legend-dot--blue { background: #007AFF; }
.stats-page__legend-dot--orange { background: #FF9500; }

/* Category Breakdown */
.stats-page__cat-row {
  display: flex; align-items: center; gap: 10rpx;
  padding: 12rpx 0;
  border-bottom: 0.5px solid #F2F2F7;
}
.stats-page__cat-row:last-child { border-bottom: none; }

.stats-page__cat-icon { font-size: 28rpx; flex-shrink: 0; }

.stats-page__cat-name {
  font-size: 26rpx; font-weight: 500; color: #1d1d1f;
  width: 72rpx; flex-shrink: 0;
}

.stats-page__cat-val {
  font-size: 24rpx; font-weight: 600; color: #8E8E93;
  width: 64rpx; text-align: right; flex-shrink: 0;
}

.stats-page__cat-bar {
  flex: 1; height: 16rpx; background: #F2F2F7;
  border-radius: 8rpx; overflow: hidden;
}

.stats-page__cat-fill {
  height: 100%; border-radius: 8rpx;
  transition: width 0.6s cubic-bezier(0.34, 1.56, 0.64, 1);
}
.stats-page__cat-fill--blue { background: linear-gradient(90deg, #007AFF, #5AC8FA); }
.stats-page__cat-fill--green { background: linear-gradient(90deg, #34C759, #80D68F); }
.stats-page__cat-fill--orange { background: linear-gradient(90deg, #FF9500, #FFB84D); }

/* Leaderboard */
.stats-page__rank-item {
  display: flex; align-items: center; gap: 10rpx;
  padding: 12rpx 0;
  border-bottom: 0.5px solid #F2F2F7;
}
.stats-page__rank-item:last-child { border-bottom: none; }

.stats-page__rank-badge {
  width: 44rpx; text-align: center; flex-shrink: 0;
}

.stats-page__rank-num {
  font-size: 26rpx; font-weight: 700; color: #C7C7CC;
}

.stats-page__rank-name {
  font-size: 26rpx; font-weight: 500; color: #1d1d1f;
  width: 80rpx; flex-shrink: 0; overflow: hidden;
  text-overflow: ellipsis; white-space: nowrap;
}

.stats-page__rank-bar-wrap {
  flex: 1; height: 12rpx; background: #F2F2F7;
  border-radius: 6rpx; overflow: hidden;
}

.stats-page__rank-bar {
  height: 100%; border-radius: 6rpx;
  background: linear-gradient(90deg, #FF9500, #FFCC00);
  transition: width 0.6s cubic-bezier(0.34, 1.56, 0.64, 1);
}

.stats-page__rank-pts {
  font-size: 24rpx; font-weight: 600; color: #FF9500;
  flex-shrink: 0; width: 96rpx; text-align: right;
}
