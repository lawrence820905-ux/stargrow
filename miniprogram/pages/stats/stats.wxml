<view class="stats-page">
  <nav-bar title="数据统计" showBack="{{true}}" />
  <view>
    <child-switcher children="{{children}}" activeId="{{activeChildId}}" bind:change="onChildChange" />

    <!-- Weekly Comparison -->
    <view class="stats-page__section" wx:if="{{comparison}}">
      <text class="stats-page__section-title">📊 本周 vs 上周</text>
      <view class="stats-page__card">
        <view class="stats-page__comp-row">
          <text class="stats-page__comp-label">完成任务</text>
          <text class="stats-page__comp-val">{{comparison.thisWeek.tasksCompleted || 0}} 次</text>
          <text class="stats-page__comp-change {{comparison.tasksChange > 0 ? 'color-green' : comparison.tasksChange < 0 ? 'color-red' : 'color-gray'}}">
            {{comparison.tasksChange > 0 ? '↑' : comparison.tasksChange < 0 ? '↓' : '→'}} {{comparison.tasksChange > 0 ? '+' : ''}}{{comparison.tasksChange}}
          </text>
        </view>
        <view class="stats-page__comp-row">
          <text class="stats-page__comp-label">获得积分</text>
          <text class="stats-page__comp-val">⭐ {{comparison.thisWeek.pointsEarned || 0}}</text>
          <text class="stats-page__comp-change {{comparison.pointsChange > 0 ? 'color-green' : comparison.pointsChange < 0 ? 'color-red' : 'color-gray'}}">
            {{comparison.pointsChange > 0 ? '↑' : comparison.pointsChange < 0 ? '↓' : '→'}} {{comparison.pointsChange > 0 ? '+' : ''}}{{comparison.pointsChange}}
          </text>
        </view>
        <view class="stats-page__comp-row">
          <text class="stats-page__comp-label">活跃类别</text>
          <text class="stats-page__comp-val">{{comparison.thisWeek.topCategory || '无'}}</text>
          <text class="stats-page__comp-trend">
            {{comparison.trend === 'up' ? '🟢 保持增长' : comparison.trend === 'down' ? '🔴 有所下降' : '🟡 保持稳定'}}
          </text>
        </view>
      </view>
    </view>

    <!-- Overview Cards -->
    <view class="stats-page__section">
      <text class="stats-page__section-title">概览</text>
      <view class="stats-page__overview-grid">
        <view class="stats-page__overview-card">
          <text class="stats-page__overview-icon">📋</text>
          <text class="stats-page__overview-value">{{overview.thisWeekTasks || 0}}</text>
          <text class="stats-page__overview-label">本周任务</text>
        </view>
        <view class="stats-page__overview-card">
          <text class="stats-page__overview-icon">⭐</text>
          <text class="stats-page__overview-value">{{overview.child ? overview.child.totalPointsEarned : 0}}</text>
          <text class="stats-page__overview-label">累计积分</text>
        </view>
        <view class="stats-page__overview-card">
          <text class="stats-page__overview-icon">🔥</text>
          <text class="stats-page__overview-value">{{overview.child ? overview.child.streakDays : 0}}<text class="stats-page__overview-unit">天</text></text>
          <text class="stats-page__overview-label">连续天数</text>
        </view>
        <view class="stats-page__overview-card">
          <text class="stats-page__overview-icon">🌳</text>
          <text class="stats-page__overview-value">Lv{{overview.child ? overview.child.level : 1}}</text>
          <text class="stats-page__overview-label">当前等级</text>
        </view>
      </view>
    </view>

    <!-- Weekly Trend Chart -->
    <view class="stats-page__section">
      <text class="stats-page__section-title">📈 每周趋势（近8周）</text>
      <view class="stats-page__card">
        <view class="stats-page__chart">
          <view class="stats-page__bars">
            <view class="stats-page__bar-col" wx:for="{{chartCompleted}}" wx:key="index">
              <view class="stats-page__bar-wrapper">
                <view
                  class="stats-page__bar"
                  style="height: {{maxCompleted > 0 ? (item / maxCompleted * 160) : 0}}rpx;"
                >
                  <text class="stats-page__bar-val" wx:if="{{item > 0}}">{{item}}</text>
                </view>
              </view>
              <text class="stats-page__bar-label">{{chartLabels[index]}}</text>
            </view>
          </view>
        </view>
        <view class="stats-page__chart-legend">
          <view class="stats-page__legend-item">
            <view class="stats-page__legend-dot stats-page__legend-dot--blue"></view>
            <text>完成任务数</text>
          </view>
          <view class="stats-page__legend-item">
            <view class="stats-page__legend-dot stats-page__legend-dot--orange"></view>
            <text>获得积分: {{chartPoints[chartPoints.length - 1] || 0}}</text>
          </view>
        </view>
      </view>
    </view>

    <!-- Category Breakdown -->
    <view class="stats-page__section">
      <text class="stats-page__section-title">📊 分类统计</text>
      <view class="stats-page__card">
        <view class="stats-page__cat-row">
          <text class="stats-page__cat-icon">⚽</text>
          <text class="stats-page__cat-name">运动</text>
          <text class="stats-page__cat-val">{{breakdown.sport || 0}} 次</text>
          <view class="stats-page__cat-bar">
            <view class="stats-page__cat-fill stats-page__cat-fill--blue" style="width: {{breakdown.sport > 0 ? (breakdown.sport / maxCat * 100) : 0}}%;"></view>
          </view>
        </view>
        <view class="stats-page__cat-row">
          <text class="stats-page__cat-icon">🏠</text>
          <text class="stats-page__cat-name">生活</text>
          <text class="stats-page__cat-val">{{breakdown.life || 0}} 次</text>
          <view class="stats-page__cat-bar">
            <view class="stats-page__cat-fill stats-page__cat-fill--green" style="width: {{breakdown.life > 0 ? (breakdown.life / maxCat * 100) : 0}}%;"></view>
          </view>
        </view>
        <view class="stats-page__cat-row">
          <text class="stats-page__cat-icon">📚</text>
          <text class="stats-page__cat-name">学习</text>
          <text class="stats-page__cat-val">{{breakdown.study || 0}} 次</text>
          <view class="stats-page__cat-bar">
            <view class="stats-page__cat-fill stats-page__cat-fill--orange" style="width: {{breakdown.study > 0 ? (breakdown.study / maxCat * 100) : 0}}%;"></view>
          </view>
        </view>
      </view>
    </view>

    <!-- Superpower Card -->
    <view class="stats-page__section" wx:if="{{superpower}}">
      <text class="stats-page__section-title">✨ 我的超能力</text>
      <view class="stats-page__card stats-page__superpower-card">
        <text class="stats-page__superpower-icon">{{superpower.icon}}</text>
        <view class="stats-page__superpower-info">
          <text class="stats-page__superpower-title">{{superpower.name}}力</text>
          <text class="stats-page__superpower-message">{{superpower.message}}</text>
        </view>
      </view>
    </view>

    <!-- Family Garden -->
    <view class="stats-page__section" wx:if="{{familyGarden.length > 0}}">
      <text class="stats-page__section-title">🌳 家庭花园</text>
      <view class="stats-page__card">
        <text class="stats-page__garden-hint">每个孩子都是一棵正在生长的植物，大家都在成长~</text>
        <view class="stats-page__garden-grid">
          <view
            class="stats-page__garden-plant {{item.childId === activeChildId ? 'stats-page__garden-plant--active' : ''}}"
            wx:for="{{familyGarden}}"
            wx:key="childId"
          >
            <text class="stats-page__garden-emoji">{{item.plantEmoji}}</text>
            <text class="stats-page__garden-name">{{item.name}}</text>
            <text class="stats-page__garden-level">Lv{{item.level}}</text>
            <text class="stats-page__garden-week">本周 {{item.weekPoints}} 分</text>
            <!-- 加油按钮：不为当前选中的孩子显示 -->
            <view
              class="stats-page__cheer-btn"
              wx:if="{{item.childId !== activeChildId}}"
              data-to-child-id="{{item.childId}}"
              bindtap="onCheerSibling"
            >
              <text>💪 加油</text>
            </view>
          </view>
        </view>
      </view>
    </view>

    <view style="height: 40rpx;"></view>
  </view>
</view>
