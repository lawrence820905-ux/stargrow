<view class="index-page">
  <!-- Status bar spacer -->
  <view style="height: {{statusBarHeight}}px;"></view>
  <!-- Top spacing -->
  <view style="height: 40rpx;"></view>
  <view style="height: 40rpx;"></view>

  <!-- Loading -->
  <block wx:if="{{loading}}">
    <view class="index-page__loading">
      <skeleton-card wx:for="{{3}}" wx:key="index" />
    </view>
  </block>

  <!-- Onboarding: 新用户引导（无孩子时展示） -->
  <block wx:elif="{{children.length === 0}}">
    <scroll-view class="index-page__onboard" scroll-y enhanced show-scrollbar="{{false}}">

      <!-- Hero 区：装饰圆环 + 浮动粒子 + 主视觉 -->
      <view class="index-page__onboard-hero">
        <!-- 装饰圆环 -->
        <view class="index-page__onboard-hero-ring"></view>
        <view class="index-page__onboard-hero-ring index-page__onboard-hero-ring--inner"></view>
        <!-- 浮动粒子 -->
        <text class="index-page__onboard-particle index-page__onboard-particle--1">✨</text>
        <text class="index-page__onboard-particle index-page__onboard-particle--2">⭐</text>
        <text class="index-page__onboard-particle index-page__onboard-particle--3">💫</text>
        <text class="index-page__onboard-particle index-page__onboard-particle--4">🌟</text>
        <!-- 主 emoji -->
        <view class="index-page__onboard-hero-emoji-wrap">
          <text class="index-page__onboard-hero-emoji">🌱</text>
        </view>
        <!-- 标题 -->
        <text class="index-page__onboard-hero-title">成长派克</text>
        <!-- 分隔装饰 -->
        <view class="index-page__onboard-hero-divider">
          <view class="index-page__onboard-hero-divider-line"></view>
          <text class="index-page__onboard-hero-divider-dot">◆</text>
          <view class="index-page__onboard-hero-divider-line"></view>
        </view>
        <text class="index-page__onboard-hero-sub">和孩子一起，让成长看得见</text>
      </view>

      <!-- 功能介绍卡片 -->
      <view class="index-page__onboard-cards">
        <view class="index-page__onboard-card index-page__onboard-card--blue" style="animation-delay: 0.1s">
          <view class="index-page__onboard-card-icon-wrap index-page__onboard-card-icon-wrap--blue">
            <text class="index-page__onboard-card-icon">📋</text>
          </view>
          <view class="index-page__onboard-card-body">
            <text class="index-page__onboard-card-title">设置每日任务</text>
            <text class="index-page__onboard-card-desc">为孩子定制运动和生活的日常小任务</text>
          </view>
        </view>
        <view class="index-page__onboard-card index-page__onboard-card--green" style="animation-delay: 0.25s">
          <view class="index-page__onboard-card-icon-wrap index-page__onboard-card-icon-wrap--green">
            <text class="index-page__onboard-card-icon">⭐</text>
          </view>
          <view class="index-page__onboard-card-body">
            <text class="index-page__onboard-card-title">完成即得积分</text>
            <text class="index-page__onboard-card-desc">每完成一个任务，孩子获得成长积分</text>
          </view>
        </view>
        <view class="index-page__onboard-card index-page__onboard-card--orange" style="animation-delay: 0.4s">
          <view class="index-page__onboard-card-icon-wrap index-page__onboard-card-icon-wrap--orange">
            <text class="index-page__onboard-card-icon">🎁</text>
          </view>
          <view class="index-page__onboard-card-body">
            <text class="index-page__onboard-card-title">积分换心愿</text>
            <text class="index-page__onboard-card-desc">积分可以抽奖或兑换孩子喜欢的奖励</text>
          </view>
        </view>
      </view>

      <!-- 操作引导步骤条：第一步高亮脉冲 -->
      <view class="index-page__onboard-steps">
        <view class="index-page__onboard-step index-page__onboard-step--active">
          <view class="index-page__onboard-step-num index-page__onboard-step-num--pulse">
            <text>①</text>
          </view>
          <text class="index-page__onboard-step-text index-page__onboard-step-text--active">添加孩子</text>
        </view>
        <view class="index-page__onboard-step-connector">
          <view class="index-page__onboard-step-dot"></view>
          <view class="index-page__onboard-step-dot"></view>
          <view class="index-page__onboard-step-dot"></view>
        </view>
        <view class="index-page__onboard-step">
          <view class="index-page__onboard-step-num"><text>②</text></view>
          <text class="index-page__onboard-step-text">创建任务</text>
        </view>
        <view class="index-page__onboard-step-connector">
          <view class="index-page__onboard-step-dot"></view>
          <view class="index-page__onboard-step-dot"></view>
          <view class="index-page__onboard-step-dot"></view>
        </view>
        <view class="index-page__onboard-step">
          <view class="index-page__onboard-step-num"><text>③</text></view>
          <text class="index-page__onboard-step-text">完成任务</text>
        </view>
        <view class="index-page__onboard-step-connector">
          <view class="index-page__onboard-step-dot"></view>
          <view class="index-page__onboard-step-dot"></view>
          <view class="index-page__onboard-step-dot"></view>
        </view>
        <view class="index-page__onboard-step">
          <view class="index-page__onboard-step-num"><text>④</text></view>
          <text class="index-page__onboard-step-text">兑换奖励</text>
        </view>
      </view>

      <!-- CTA 按钮 -->
      <view class="index-page__onboard-cta-wrap">
        <button class="index-page__onboard-cta" bindtap="onStartOnboarding">
          <text class="index-page__onboard-cta-text">✨ 添加我的孩子</text>
        </button>
      </view>

    </scroll-view>
  </block>

  <!-- Content -->
  <block wx:else>
    <!-- Child Switcher -->
    <child-switcher children="{{children}}" activeId="{{activeChildId}}" bind:change="onChildChange" />

    <!-- Level Tree with left/right arrows -->
    <view class="index-page__level-row" wx:if="{{children.length > 1}}">
      <view class="index-page__switch-btn index-page__switch-btn--left" bindtap="onPrevChild">
        <text class="index-page__switch-arrow">‹</text>
      </view>
      <level-tree totalPoints="{{activeChild.totalPointsEarned}}" level="{{activeChild.level}}" />
      <view class="index-page__switch-btn index-page__switch-btn--right" bindtap="onNextChild">
        <text class="index-page__switch-arrow">›</text>
      </view>
    </view>
    <level-tree wx:else totalPoints="{{activeChild.totalPointsEarned}}" level="{{activeChild.level}}" />

    <!-- Points & Streak -->
    <view class="index-page__stats-row">
      <view class="index-page__stat-card">
        <points-display value="{{activeChild.currentPoints}}" label="积分" animate="{{pointsAnimate}}" />
      </view>
      <view class="index-page__stat-card">
        <streak-badge days="{{activeChild.streakDays}}" />
      </view>
    </view>

    <!-- Growth Story Card -->
    <view class="index-page__section" wx:if="{{growthStory || growthStoryLoading}}">
      <growth-story-card story="{{growthStory}}" loading="{{growthStoryLoading}}" />
    </view>

    <!-- Pending Promises Alert -->
    <view class="index-page__section" wx:if="{{pendingPromises.length > 0}}">
      <view class="index-page__promise-card" bindtap="onGoPromises">
        <text class="index-page__promise-icon">🤝</text>
        <view class="index-page__promise-info">
          <text class="index-page__promise-title">你有 <text class="index-page__promise-num">{{pendingPromises.length}}</text> 个承诺等待兑现</text>
          <text class="index-page__promise-hint" wx:if="{{pendingPromises[0].isOverdue}}">部分已超过承诺期限，和孩子聊一聊吧~</text>
          <text class="index-page__promise-hint" wx:else>别忘了兑现给孩子的承诺哦~</text>
        </view>
        <view class="index-page__promise-arrow">
          <text>→</text>
        </view>
      </view>
    </view>

    <!-- Today Progress -->
    <view class="index-page__section">
      <view class="index-page__section-header">
        <text class="index-page__section-title">今日任务</text>
      </view>
      <view class="index-page__progress-card">
        <view class="index-page__progress-bar-wrap">
          <view class="index-page__progress-bar" style="width: {{todayPercent}}%;"></view>
        </view>
        <view class="index-page__progress-info">
          <text class="index-page__progress-text">今天还可以获得{{todayMaxPoints}}分哦 · {{todayCompleted}}/{{todayTasks}}已完成</text>
        </view>
      </view>
      <!-- Today task preview -->
      <view wx:if="{{todayTasksList.length > 0}}">
        <task-card
          wx:for="{{todayTasksList}}"
          wx:key="_id"
          task="{{item}}"
          bind:tasktap="onTaskTap"
        />
      </view>
      <empty-state wx:else icon="📋" text="今天还没有任务" />
    </view>

    <!-- Recent Loot -->
    <view class="index-page__section" wx:if="{{recentDraws.length > 0}}">
      <view class="index-page__section-header">
        <text class="index-page__section-title">最近战利品</text>
      </view>
      <view class="index-page__loot-list">
        <view class="index-page__loot-item" wx:for="{{recentDraws}}" wx:key="_id">
          <text class="index-page__loot-icon">{{item.prizeType === 'points' ? '⭐' : '🎁'}}</text>
          <text class="index-page__loot-name">{{item.prizeName}}</text>
        </view>
      </view>
    </view>
  </block>

  <view class="safe-area-bottom" style="height: 160rpx;"></view>
</view>
