<view class="index-page">
  <!-- Status bar spacer -->
  <view style="height: {{statusBarHeight}}px;"></view>

  <!-- Loading -->
  <block wx:if="{{loading}}">
    <view class="index-page__loading">
      <skeleton-card wx:for="{{3}}" wx:key="index" />
    </view>
  </block>

  <!-- No Children -->
  <block wx:elif="{{children.length === 0}}">
    <empty-state icon="👶" text="还没有添加孩子哦~&#10;快去设置页面添加吧" actionText="添加孩子" bind:action="onAddChild" />
  </block>

  <!-- Content -->
  <block wx:else>
    <!-- Child Switcher -->
    <child-switcher children="{{children}}" activeId="{{activeChildId}}" bind:change="onChildChange" />

    <!-- Level Tree -->
    <level-tree totalPoints="{{activeChild.totalPointsEarned}}" level="{{activeChild.level}}" />

    <!-- Points & Streak -->
    <view class="index-page__stats-row">
      <view class="index-page__stat-card">
        <points-display value="{{activeChild.currentPoints}}" label="积分" animate="{{pointsAnimate}}" />
      </view>
      <view class="index-page__stat-card">
        <streak-badge days="{{activeChild.streakDays}}" />
      </view>
    </view>

    <!-- Growth Story Card -->
    <view class="index-page__section" wx:if="{{growthStory || growthStoryLoading}}">
      <growth-story-card story="{{growthStory}}" loading="{{growthStoryLoading}}" />
    </view>

    <!-- Pending Promises Alert -->
    <view class="index-page__section" wx:if="{{pendingPromises.length > 0}}">
      <view class="index-page__promise-card">
        <text class="index-page__promise-icon">🤝</text>
        <view class="index-page__promise-info">
          <text class="index-page__promise-title">你有 <text class="index-page__promise-num">{{pendingPromises.length}}</text> 个承诺等待兑现</text>
          <text class="index-page__promise-hint" wx:if="{{pendingPromises[0].isOverdue}}">部分已超过承诺期限，和孩子聊一聊吧~</text>
          <text class="index-page__promise-hint" wx:else>别忘了兑现给孩子的承诺哦~</text>
        </view>
        <view class="index-page__promise-arrow">
          <text>→</text>
        </view>
      </view>
    </view>

    <!-- Today Progress -->
    <view class="index-page__section">
      <view class="index-page__section-header">
        <text class="index-page__section-title">今日任务</text>
      </view>
      <view class="index-page__progress-card">
        <view class="index-page__progress-bar-wrap">
          <view class="index-page__progress-bar" style="width: {{todayPercent}}%;"></view>
        </view>
        <view class="index-page__progress-info">
          <text class="index-page__progress-text">今天还可以获得{{todayMaxPoints}}分哦 · {{todayCompleted}}/{{todayTasks}}已完成</text>
        </view>
      </view>
      <!-- Today task preview -->
      <view wx:if="{{todayTasksList.length > 0}}">
        <task-card
          wx:for="{{todayTasksList}}"
          wx:key="_id"
          task="{{item}}"
          bind:tasktap="onTaskTap"
        />
      </view>
      <empty-state wx:else icon="📋" text="今天还没有任务" />
    </view>

    <!-- Recent Loot -->
    <view class="index-page__section" wx:if="{{recentDraws.length > 0}}">
      <view class="index-page__section-header">
        <text class="index-page__section-title">最近战利品</text>
      </view>
      <view class="index-page__loot-list">
        <view class="index-page__loot-item" wx:for="{{recentDraws}}" wx:key="_id">
          <text class="index-page__loot-icon">{{item.prizeType === 'points' ? '⭐' : '🎁'}}</text>
          <text class="index-page__loot-name">{{item.prizeName}}</text>
        </view>
      </view>
    </view>
  </block>

  <view class="safe-area-bottom" style="height: 160rpx;"></view>
</view>
