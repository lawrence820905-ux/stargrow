<view class="ach-page">
  <nav-bar title="成就墙" />
  <child-switcher children="{{children}}" activeId="{{activeChildId}}" bind:change="onChildChange" />

  <view class="ach-page__count">
    <text>{{earned.length}} / {{total}} 已获得</text>
  </view>

  <view class="ach-page__grid" wx:if="{{allBadges.length > 0}}">
    <view
      class="ach-page__badge {{item.earnedAt ? 'ach-page__badge--earned' : 'ach-page__badge--locked'}}"
      wx:for="{{allBadges}}"
      wx:key="key"
    >
      <text class="ach-page__badge-icon">{{item.icon}}</text>
      <text class="ach-page__badge-name">{{item.name}}</text>
      <text class="ach-page__badge-desc">{{item.description}}</text>
    </view>
  </view>

  <empty-state wx:else icon="🏅" text="还没有解锁成就" hint="完成更多任务来解锁成就吧" />

  <view class="safe-area-bottom" style="height: 120rpx;"></view>
</view>
