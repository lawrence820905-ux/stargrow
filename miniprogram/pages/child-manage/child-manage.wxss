/* iOS Child Manage */
.cm-page { min-height: 100vh; background: #F2F2F7; }
.cm-page__content { padding: 16rpx 32rpx; }

.cm-page__child {
  display: flex; align-items: center; gap: 12rpx;
  padding: 16rpx; background: #FFFFFF;
  border-radius: 16rpx; margin-bottom: 8rpx;
  box-shadow: 0 2px 16px rgba(0,0,0,0.04);
}
.cm-page__child:active { transform: scale(0.98); }

.cm-page__child-avatar {
  width: 64rpx; height: 64rpx; border-radius: 50%; overflow: hidden;
  background: rgba(0,122,255,0.1);
  display: flex; align-items: center; justify-content: center;
}
.cm-page__child-avatar image { width: 100%; height: 100%; }
.cm-page__avatar-text { font-size: 28rpx; font-weight: 700; color: #007AFF; }
.cm-page__child-name { flex: 1; font-size: 28rpx; font-weight: 600; color: #1d1d1f; }
.cm-page__child-level { font-size: 22rpx; color: #C7C7CC; }
.cm-page__child-actions { display: flex; gap: 12rpx; }

.cm-page__edit-btn { font-size: 26rpx; color: #007AFF; }
.cm-page__edit-btn:active { transform: scale(0.9); opacity: 0.6; }
.cm-page__delete-btn { font-size: 26rpx; color: #FF3B30; }
.cm-page__delete-btn:active { transform: scale(0.9); opacity: 0.6; }

.cm-page__add-btn {
  text-align: center; padding: 16rpx;
  background: #FFFFFF;
  border-radius: 16rpx; font-size: 28rpx; color: #007AFF;
  margin-top: 8rpx; box-shadow: 0 2px 16px rgba(0,0,0,0.04);
}
.cm-page__add-btn:active { transform: scale(0.97); }

/* Modal */
.cm-page__overlay {
  position: fixed; top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.4); z-index: 200;
  display: flex; align-items: center; justify-content: center;
  animation: fade-in 0.25s ease forwards;
}
@keyframes fade-in { from { opacity: 0; } to { opacity: 1; } }

.cm-page__modal {
  width: 540rpx;
  background: #FFFFFF;
  border-radius: 20rpx; padding: 32rpx;
  animation: modal-pop 0.2s ease forwards;
}
@keyframes modal-pop { from { transform: scale(0.85); opacity: 0; } to { transform: scale(1); opacity: 1; } }

.cm-page__modal-title {
  font-size: 28rpx; font-weight: 600; text-align: center;
  display: block; margin-bottom: 16rpx; color: #1d1d1f;
}

.cm-page__input {
  background: #F2F2F7; border-radius: 10rpx;
  padding: 12rpx; font-size: 28rpx; margin-bottom: 16rpx;
}

.cm-page__modal-btns { display: flex; gap: 12rpx; }

.cm-page__modal-cancel, .cm-page__modal-confirm {
  flex: 1; height: 48rpx; line-height: 48rpx;
  border-radius: 12rpx; font-size: 28rpx; font-weight: 600;
  text-align: center; border: none; transition: all 0.2s ease;
}
.cm-page__modal-cancel::after, .cm-page__modal-confirm::after { border: none; }
.cm-page__modal-cancel:active, .cm-page__modal-confirm:active { transform: scale(0.96); }
.cm-page__modal-cancel {
  background: rgba(242,242,247,0.8);
  color: #8E8E93;
}
.cm-page__modal-confirm {
  background: #007AFF; color: #FFFFFF;
}
