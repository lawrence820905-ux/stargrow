/* iOS Child Detail */
.cd-page { min-height: 100vh; background: var(--color-background); padding-bottom: 60rpx; }

.cd-page__stats {
  display: flex; gap: 12rpx;
  padding: 0 32rpx 16rpx;
}

.cd-page__stat {
  flex: 1;
  background: #FFFFFF;
  border-radius: 20rpx; padding: 16rpx;
  display: flex; align-items: center; justify-content: center;
  box-shadow: var(--shadow-card);
}

.cd-page__card {
  margin: 0 32rpx;
  background: #FFFFFF;
  border-radius: 20rpx; overflow: hidden; box-shadow: var(--shadow-card);
}

.cd-page__row {
  display: flex; justify-content: space-between;
  padding: 16rpx;
  border-bottom: 0.5px solid #E8E8E8;
  font-size: 28rpx; color: #3C3C3C;
}
.cd-page__row:last-child { border-bottom: none; }
.cd-page__val { font-weight: 800; color: #58CC02; }

/* Observation */
.cd-page__section { margin: 24rpx 32rpx; }

.cd-page__section-header {
  display: flex; align-items: center; justify-content: space-between;
  margin-bottom: 16rpx;
}

.cd-page__section-title {
  font-size: 26rpx; font-weight: 700; color: #3C3C3C;
}

.cd-page__add-btn {
  padding: 8rpx 20rpx;
  background: linear-gradient(135deg, #46A800, #58CC02);
  border-radius: 999px;
}
.cd-page__add-btn:active { opacity: 0.7; }
.cd-page__add-btn text {
  font-size: 24rpx; color: #FFFFFF; font-weight: 700;
}

.cd-page__obs-list { display: flex; flex-direction: column; gap: 12rpx; }

.cd-page__obs-item {
  background: #FFFFFF; border-radius: 20rpx; padding: 20rpx 24rpx;
  box-shadow: 0 4px 0 rgba(0,0,0,0.06), 0 2px 8px rgba(0,0,0,0.04);
}

.cd-page__obs-header {
  display: flex; align-items: center; gap: 8rpx;
  margin-bottom: 8rpx;
}

.cd-page__obs-mood { font-size: 28rpx; }

.cd-page__obs-time {
  font-size: 24rpx; color: #A0A0A0; flex: 1;
}

.cd-page__obs-del {
  width: 44rpx; height: 44rpx;
  display: flex; align-items: center; justify-content: center;
  font-size: 24rpx;
}
.cd-page__obs-del:active { opacity: 0.5; }

.cd-page__obs-content {
  font-size: 26rpx; color: #3C3C3C; line-height: 1.6;
  display: block;
}

/* Add Observation Modal */
.cd-page__overlay {
  position: fixed; top: 0; left: 0; right: 0; bottom: 0; z-index: 500;
  display: flex; align-items: flex-end; justify-content: center;
}
.cd-page__overlay-bg {
  position: absolute; top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.4);
}
.cd-page__obs-modal {
  position: relative; z-index: 1;
  background: #FFFFFF; border-radius: 32rpx 32rpx 0 0;
  width: 100%; padding: 32rpx;
  animation: cdModalUp 0.3s ease;
}
@keyframes cdModalUp {
  from { transform: translateY(100%); }
  to { transform: translateY(0); }
}

.cd-page__obs-modal-title {
  font-size: 32rpx; font-weight: 700; color: #3C3C3C;
  display: block; text-align: center; margin-bottom: 24rpx;
}

.cd-page__mood-row {
  display: flex; align-items: center; gap: 12rpx;
  margin-bottom: 16rpx;
}
.cd-page__mood-label {
  font-size: 24rpx; color: #8E8E93; font-weight: 600;
}
.cd-page__mood-item {
  width: 60rpx; height: 60rpx; border-radius: 16rpx;
  background: #F5F5F5;
  display: flex; align-items: center; justify-content: center;
  transition: all 0.15s ease;
}
.cd-page__mood-item text { font-size: 32rpx; }
.cd-page__mood-item--active {
  background: #EEF8FF; box-shadow: 0 0 0 3px #1CB0F6;
}

.cd-page__obs-input {
  width: 100%; min-height: 160rpx;
  padding: 16rpx 20rpx;
  background: #F5F5F5; border-radius: 16rpx;
  font-size: 28rpx; color: #3C3C3C;
  box-sizing: border-box;
}
.cd-page__obs-count {
  font-size: 24rpx; color: #A0A0A0;
  display: block; text-align: right; margin-top: 4rpx;
}

.cd-page__obs-btns {
  display: flex; gap: 16rpx; margin-top: 24rpx;
}
.cd-page__obs-cancel {
  flex: 1; padding: 20rpx 0; border-radius: 999px;
  background: #F5F5F5; font-size: 28rpx; color: #8E8E93;
  font-weight: 600; text-align: center; border: none;
}
.cd-page__obs-submit {
  flex: 1; padding: 20rpx 0; border-radius: 999px;
  background: linear-gradient(135deg, #46A800, #58CC02);
  font-size: 28rpx; color: #FFFFFF; font-weight: 700;
  text-align: center; border: none;
  box-shadow: 0 4px 16px rgba(88,204,2,0.25);
}
