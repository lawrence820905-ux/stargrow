/* iOS Child Detail */
.cd-page { min-height: 100vh; background: #F2F2F7; padding-bottom: 60rpx; }

.cd-page__stats {
  display: flex; gap: 12rpx;
  padding: 0 32rpx 16rpx;
}

.cd-page__stat {
  flex: 1;
  background: #FFFFFF;
  border-radius: 16rpx; padding: 16rpx;
  display: flex; align-items: center; justify-content: center;
  box-shadow: 0 2px 16px rgba(0,0,0,0.04);
}

.cd-page__card {
  margin: 0 32rpx;
  background: #FFFFFF;
  border-radius: 16rpx; overflow: hidden; box-shadow: 0 2px 16px rgba(0,0,0,0.04);
}

.cd-page__row {
  display: flex; justify-content: space-between;
  padding: 16rpx;
  border-bottom: 0.5px solid #C6C6C8;
  font-size: 28rpx; color: #1d1d1f;
}
.cd-page__row:last-child { border-bottom: none; }
.cd-page__val { font-weight: 700; color: #007AFF; }
