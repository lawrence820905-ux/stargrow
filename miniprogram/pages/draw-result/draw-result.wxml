<view class="dr-page">
  <confetti-view id="confetti" />
  <view class="dr-page__content">
    <text class="dr-page__title">恭喜获得!</text>
    <text class="dr-page__icon">{{prizeType === 'points' ? '⭐' : '🎁'}}</text>
    <text class="dr-page__prize">{{prizeName}}</text>
    <text class="dr-page__points" wx:if="{{pointsAwarded > 0}}">+{{pointsAwarded}} 积分</text>
    <text class="dr-page__reward" wx:if="{{rewardTitle}}">{{rewardTitle}}</text>
    <button class="dr-page__btn" bindtap="onDone">太棒了!</button>
  </view>
</view>
