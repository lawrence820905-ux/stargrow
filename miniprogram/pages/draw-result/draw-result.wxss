/* Duolingo Draw Result 鈥?centered celebration */
.dr-page {
  min-height: 100vh;
  background: linear-gradient(180deg, var(--color-background), var(--color-background-white));
  display: flex; align-items: center; justify-content: center;
}

.dr-page__content {
  display: flex; flex-direction: column; align-items: center;
  padding: 48rpx;
}

.dr-page__title {
  font-size: 24rpx; color: #A0A0A0; font-weight: 600; margin-bottom: 16rpx;
}

.dr-page__icon { font-size: 96rpx; margin-bottom: 16rpx; }

.dr-page__prize {
  font-size: 32rpx; font-weight: 800; margin-bottom: 8rpx;
  text-align: center; color: #3C3C3C;
}

.dr-page__points {
  font-size: 24rpx; font-weight: 700; color: #58CC02; margin-bottom: 4rpx;
}

.dr-page__reward {
  font-size: 24rpx; color: #FF9600; font-weight: 600; margin-bottom: 48rpx;
}

.dr-page__btn {
  width: 320rpx; height: 56rpx; line-height: 56rpx;
  background: linear-gradient(135deg, #46A800, #58CC02); color: #FFFFFF;
  border-radius: 32rpx; font-size: 30rpx; font-weight: 700;
  border: none; box-shadow: var(--shadow-glow-green);
  transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
}
.dr-page__btn::after { border: none; }
.dr-page__btn:active { transform: scale(0.96); }
