/* iOS Draw Result — centered celebration */
.dr-page {
  min-height: 100vh;
  background: linear-gradient(180deg, rgba(0,122,255,0.05), #F2F2F7);
  display: flex; align-items: center; justify-content: center;
}

.dr-page__content {
  display: flex; flex-direction: column; align-items: center;
  padding: 48rpx;
}

.dr-page__title {
  font-size: 20rpx; color: #8E8E93; margin-bottom: 16rpx;
}

.dr-page__icon { font-size: 96rpx; margin-bottom: 16rpx; }

.dr-page__prize {
  font-size: 28rpx; font-weight: 700; margin-bottom: 8rpx;
  text-align: center; color: #1d1d1f;
}

.dr-page__points {
  font-size: 22rpx; font-weight: 600; color: #007AFF; margin-bottom: 4rpx;
}

.dr-page__reward {
  font-size: 17rpx; color: #FF9500; margin-bottom: 48rpx;
}

.dr-page__btn {
  width: 320rpx; height: 52rpx; line-height: 52rpx;
  background: #007AFF; color: #FFFFFF;
  border-radius: 12rpx; font-size: 17rpx; font-weight: 600;
  border: none; box-shadow: 0 4rpx 16rpx rgba(0,122,255,0.3);
  transition: all 0.2s ease;
}
.dr-page__btn::after { border: none; }
.dr-page__btn:active { transform: scale(0.97); }
