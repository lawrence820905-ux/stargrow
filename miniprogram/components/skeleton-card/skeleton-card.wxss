/* Duolingo Skeleton Card */
.skeleton-card {
  background: #FFFFFF; border-radius: 24rpx; padding: 24rpx; margin-bottom: 16rpx;
  box-shadow: 0 4px 0 rgba(0,0,0,0.04), 0 2px 8px rgba(0,0,0,0.02);
}

.skeleton-pulse {
  background: linear-gradient(90deg, #F5F5F5 25%, #ECECEC 50%, #F5F5F5 75%);
  background-size: 200% 100%;
  animation: skeleton-pulse 1.5s ease-in-out infinite;
  border-radius: 8rpx;
}

@keyframes skeleton-pulse {
  0% { background-position: 200% 0; }
  100% { background-position: -200% 0; }
}

.skeleton-card__header {
  display: flex; justify-content: space-between; margin-bottom: 16rpx;
}

.skeleton-card__tag { width: 100rpx; height: 36rpx; }

.skeleton-card__status { height: 24rpx; }

.skeleton-card__body { margin-bottom: 16rpx; }

.skeleton-card__title { height: 32rpx; margin-bottom: 8rpx; }

.skeleton-card__desc { height: 24rpx; }

.skeleton-card__footer { padding-top: 8rpx; }

.skeleton-card__pts { height: 28rpx; }
