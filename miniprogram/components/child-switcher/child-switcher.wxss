.child-switcher { width: 100%; white-space: nowrap; }

.child-switcher__list {
  display: inline-flex; padding: 16rpx 32rpx; gap: 24rpx;
}

.child-switcher__item {
  display: flex; flex-direction: column; align-items: center;
  gap: 8rpx; opacity: 0.5; transition: opacity 0.2s;
}

.child-switcher__item--active { opacity: 1; }

.child-switcher__avatar {
  width: 96rpx; height: 96rpx; border-radius: 50%; overflow: hidden;
  border: 3rpx solid transparent; transition: border-color 0.2s;
}

.child-switcher__item--active .child-switcher__avatar {
  border-color: #58CC02;
  border-width: 4rpx;
  box-shadow: 0 4px 16px rgba(88,204,2,0.25);
}

.child-switcher__avatar-img { width: 100%; height: 100%; }

.child-switcher__avatar-placeholder {
  width: 100%; height: 100%; background: #EEF8FF;
  display: flex; align-items: center; justify-content: center;
  font-size: 40rpx; font-weight: 700; color: #1CB0F6;
}

.child-switcher__name {
  font-size: 24rpx; color: #3C3C3C; font-weight: 500;
  max-width: 120rpx; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
}
