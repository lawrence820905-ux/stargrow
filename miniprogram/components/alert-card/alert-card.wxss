.alert-card {
  display: flex; align-items: center; gap: 12rpx;
  padding: 20rpx 24rpx; border-radius: 20rpx;
  box-shadow: 0 4px 0 rgba(0,0,0,0.06), 0 2px 8px rgba(0,0,0,0.04);
  animation: alertIn 0.3s ease;
}
@keyframes alertIn {
  from { opacity: 0; transform: translateY(-20rpx); }
  to { opacity: 1; transform: translateY(0); }
}

.alert-card--suggestion { background: #EEF8FF; }
.alert-card--warning { background: #FFF3CD; }
.alert-card--info { background: #F5F5F5; }

.alert-card__icon { font-size: 32rpx; flex-shrink: 0; }

.alert-card__msg {
  flex: 1; font-size: 24rpx; color: #3C3C3C;
  line-height: 1.5; font-weight: 500;
}

.alert-card__close {
  width: 44rpx; height: 44rpx;
  display: flex; align-items: center; justify-content: center;
  font-size: 24rpx; color: #A0A0A0; flex-shrink: 0;
}
.alert-card__close:active { opacity: 0.5; }
