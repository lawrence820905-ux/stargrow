.score-stars {
  display: flex; align-items: stretch; justify-content: center; gap: 16rpx;
}

.score-stars__option {
  flex: 1; display: flex; flex-direction: column;
  align-items: center; justify-content: center;
  padding: 24rpx 12rpx; border-radius: 16rpx;
  border: 2rpx solid #C6C6C8; background: #FFFFFF;
  transition: all 0.2s;
}

.score-stars__option--hover { transform: scale(1.03); }

.score-stars__option--active {
  border-color: #007AFF; background: #E8F2FF;
}

.score-stars__option-icon { font-size: 52rpx; margin-bottom: 8rpx; }

.score-stars__option-label {
  font-size: 26rpx; font-weight: 600; color: #8E8E93; margin-bottom: 4rpx;
}

.score-stars__option--active .score-stars__option-label { color: #007AFF; }

.score-stars__option-subtext { font-size: 20rpx; color: #8E8E93; }

.score-stars__option--active .score-stars__option-subtext { color: #007AFF; }
