/* Score Stars — 修复版：防遮挡 */
.score-stars {
  display: flex; align-items: stretch; justify-content: center; gap: 10rpx;
  width: 100%;
}

.score-stars__item {
  flex: 1; min-width: 0;
  display: flex; flex-direction: column; align-items: center; gap: 6rpx;
}

.score-stars__option {
  width: 100%; box-sizing: border-box;
  display: flex; flex-direction: column;
  align-items: center; justify-content: center;
  padding: 20rpx 8rpx; border-radius: 16rpx;
  border: 2rpx solid #E8E8E8; background: #FFFFFF;
  transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
}

.score-stars__option--hover { transform: scale(1.03); }

.score-stars__option--active {
  border-color: #58CC02; background: #F0FFE8;
  box-shadow: 0 4px 16px rgba(88,204,2,0.20);
}

.score-stars__option-icon { font-size: 44rpx; margin-bottom: 4rpx; }

.score-stars__option-label {
  font-size: 26rpx; font-weight: 700; color: #A0A0A0;
  text-align: center; line-height: 1.3; margin-bottom: 6rpx;
}

.score-stars__option--active .score-stars__option-label { color: #3C3C3C; }

/* Rubric Tag */
.score-stars__option-rubric {
  padding: 4rpx 16rpx; border-radius: 100rpx;
  font-size: 20rpx; font-weight: 600;
}

.score-stars__option-rubric--s1 { background: #FFF3E0; color: #FF9500; }
.score-stars__option-rubric--s2 { background: #E8F2FF; color: #007AFF; }
.score-stars__option-rubric--s3 { background: #F0FFE8; color: #58CC02; }

.score-stars__option--active .score-stars__option-rubric--s1 { background: #FF9500; color: #FFFFFF; }
.score-stars__option--active .score-stars__option-rubric--s2 { background: #007AFF; color: #FFFFFF; }
.score-stars__option--active .score-stars__option-rubric--s3 { background: #58CC02; color: #FFFFFF; }

.score-stars__subtext {
  font-size: 24rpx; color: #A0A0A0; text-align: center; font-weight: 400;
  line-height: 1.3;
  word-break: break-all;
}
