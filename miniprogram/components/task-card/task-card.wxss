.task-card {
  background: #FFFFFF;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2px 16px rgba(0,0,0,0.04);
  transition: transform 0.2s;
}

.task-card:active {
  transform: scale(0.98);
}

.task-card--completed {
  opacity: 0.7;
}

.task-card__header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 12rpx;
}

.task-card__header-left {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.task-card__type-badge {
  background: #E8F2FF;
  border: 1rpx solid #007AFF;
  border-radius: 8rpx;
  padding: 2rpx 12rpx;
}

.task-card__type-text {
  font-size: 20rpx;
  color: #007AFF;
  font-weight: 500;
}

.task-card__status-text {
  font-size: 22rpx;
  font-weight: 500;
}

.color-green { color: #34C759; }
.color-orange { color: #FF9500; }

.task-card__body {
  margin-bottom: 16rpx;
}

.task-card__title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1d1d1f;
  line-height: 1.4;
}

.task-card__desc {
  font-size: 24rpx;
  color: #8E8E93;
  margin-top: 4rpx;
  line-height: 1.3;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.task-card__footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.task-card__points {
  display: flex;
  align-items: center;
  gap: 6rpx;
}

.task-card__points-icon {
  font-size: 24rpx;
}

.task-card__points-text {
  font-size: 24rpx;
  color: #8E8E93;
  font-weight: 500;
}

.task-card__score {
  font-size: 22rpx;
  color: #007AFF;
  margin-left: 8rpx;
}

.task-card__time {
  font-size: 22rpx;
  color: #C7C7CC;
}
