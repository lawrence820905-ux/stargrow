.gsc-card {
  background: linear-gradient(135deg, #F0FFE8, #E8FFF0);
  border: 2rpx solid #C8E8C0;
  border-radius: 24rpx; padding: 28rpx 24rpx;
  box-shadow: 0 2px 12px rgba(88,204,2,0.08);
}

.gsc-card--loading {
  background: #F9F9FB;
  border-color: #E5E5EA;
  text-align: center;
}

.gsc-card__loading-text {
  font-size: 26rpx; color: #A0A0A0;
}

.gsc-card__header {
  display: flex; align-items: center; gap: 10rpx;
  margin-bottom: 4rpx;
}

.gsc-card__icon { font-size: 36rpx; }

.gsc-card__title {
  font-size: 28rpx; font-weight: 800; color: #3C3C3C;
}

.gsc-card__date {
  font-size: 22rpx; color: #A0A0A0; display: block; margin-bottom: 12rpx;
}

.gsc-card__story {
  font-size: 26rpx; color: #3C3C3C; line-height: 1.8;
  display: block; margin-bottom: 12rpx;
}

/* Highlights */
.gsc-card__highlights {
  display: flex; flex-direction: column; gap: 6rpx;
  margin-bottom: 16rpx; padding: 12rpx 16rpx;
  background: rgba(255,255,255,0.6); border-radius: 12rpx;
}
.gsc-card__highlight {
  display: flex; align-items: flex-start; gap: 6rpx;
}
.gsc-card__highlight-dot { font-size: 22rpx; flex-shrink: 0; margin-top: 2rpx; }
.gsc-card__highlight-text {
  font-size: 24rpx; color: #5C7C50; line-height: 1.5;
}

/* New Tasks */
.gsc-card__new-tasks {
  margin-bottom: 16rpx;
}
.gsc-card__new-label {
  font-size: 24rpx; font-weight: 600; color: #58CC02;
  display: block; margin-bottom: 8rpx;
}
.gsc-card__new-tags {
  display: flex; flex-wrap: wrap; gap: 8rpx;
}
.gsc-card__new-tag {
  padding: 4rpx 12rpx; border-radius: 100rpx;
  font-size: 22rpx; color: #58CC02; font-weight: 500;
  background: rgba(88,204,2,0.1); border: 1px solid rgba(88,204,2,0.2);
}

/* Encouragement */
.gsc-card__encouragement {
  padding: 16rpx; margin-bottom: 12rpx;
  background: rgba(88,204,2,0.06); border-radius: 12rpx;
  text-align: center;
}
.gsc-card__encouragement text {
  font-size: 26rpx; font-weight: 600; color: #46A800;
}

.gsc-card__stats {
  display: flex; gap: 24rpx; padding-top: 12rpx;
  border-top: 1px solid #D8F0D0;
}

.gsc-card__stat {
  font-size: 24rpx; color: #58CC02; font-weight: 600;
}
