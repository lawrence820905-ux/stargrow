<view class="progress-ring">
  <canvas
    type="2d"
    id="ring-canvas"
    class="progress-ring__canvas"
    style="width: {{size}}rpx; height: {{size}}rpx;"
  ></canvas>
  <view class="progress-ring__center">
    <text class="progress-ring__value">{{current}}</text>
    <text class="progress-ring__total">/ {{total}}</text>
  </view>
</view>
