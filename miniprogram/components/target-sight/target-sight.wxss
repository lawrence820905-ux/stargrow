.ts {
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 24rpx;
  box-shadow: 0 4px 0 rgba(0,0,0,0.06), 0 2px 8px rgba(0,0,0,0.04);
}

.ts__header {
  display: flex; align-items: baseline; justify-content: space-between;
  margin-bottom: 16rpx;
}

.ts__title {
  font-size: 26rpx; font-weight: 700; color: #3C3C3C;
}

.ts__subtitle {
  font-size: 24rpx; color: #A0A0A0; font-weight: 600;
}

.ts__bar-wrap {
  width: 100%; height: 20rpx;
  background: #F5F5F5;
  border-radius: 10rpx; overflow: hidden;
  margin-bottom: 12rpx;
  box-shadow: inset 0 2px 6px rgba(0,0,0,0.06);
}

.ts__bar {
  height: 100%; border-radius: 10rpx;
  background: linear-gradient(90deg, #FF9600, #FFC800);
  box-shadow: 0 0 10px rgba(255,150,0,0.20);
  transition: width 0.6s cubic-bezier(0.34, 1.56, 0.64, 1);
}

.ts__info {
  display: flex; align-items: baseline; justify-content: space-between;
}

.ts__current {
  font-size: 32rpx; font-weight: 800; color: #FF9600;
}

.ts__goal {
  font-size: 24rpx; color: #A0A0A0;
}

.ts__goal-name {
  color: #58CC02; font-weight: 700;
}
