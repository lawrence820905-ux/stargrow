<view class="ts">
  <view class="ts__header">
    <text class="ts__title">🎯 目标进度</text>
    <text class="ts__subtitle" wx:if="{{remainingPoints > 0}}">今天还能获得 ~{{remainingPoints}} 分</text>
  </view>

  <view class="ts__bar-wrap">
    <view class="ts__bar" style="width: {{percent}}%;"></view>
  </view>

  <view class="ts__info">
    <text class="ts__current">⭐ {{currentPoints}}</text>
    <text class="ts__goal">
      距离<text class="ts__goal-name">{{nearestGoalName}}</text>还差 {{nearestGoal - currentPoints > 0 ? nearestGoal - currentPoints : 0}} 分
    </text>
  </view>
</view>
