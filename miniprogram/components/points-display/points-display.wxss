.points-display {
  display: flex; align-items: center; justify-content: center; gap: 8rpx;
}

.points-display__icon { font-size: 36rpx; }

.points-display__value {
  font-size: 48rpx; font-weight: 700;
  font-family: -apple-system, 'Helvetica Neue', monospace; color: #1d1d1f;
}

.points-display__value--animate {
  animation: points-pop 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
}

@keyframes points-pop {
  0% { transform: scale(1); }
  50% { transform: scale(1.3); color: #FF9500; }
  100% { transform: scale(1); }
}

.points-display__label { font-size: 26rpx; color: #8E8E93; }
