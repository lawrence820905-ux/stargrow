/* Duolingo ABC Points Display */
.points-display {
  display: flex; align-items: center; justify-content: center; gap: 8rpx;
}

.points-display__icon { font-size: 40rpx; }

.points-display__value {
  font-size: 56rpx; font-weight: 800;
  font-family: -apple-system, 'Helvetica Neue', monospace;
  color: #58CC02;
}

.points-display__value--animate {
  animation: points-pop 0.5s cubic-bezier(0.34, 1.56, 0.64, 1);
}

@keyframes points-pop {
  0% { transform: scale(1); }
  40% { transform: scale(1.3); color: #FFC800; }
  100% { transform: scale(1); }
}

.points-display__label { font-size: 26rpx; color: #A0A0A0; font-weight: 500; }
