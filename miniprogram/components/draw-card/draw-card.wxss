.draw-card {
  background: #FFFFFF; border-radius: 32rpx; padding: 32rpx;
  box-shadow: var(--shadow-card);
}

.draw-card__header {
  display: flex; align-items: center; gap: 16rpx; margin-bottom: 24rpx;
}

.draw-card__icon { font-size: 52rpx; }

.draw-card__header-text { display: flex; flex-direction: column; }

.draw-card__title {
  font-size: 32rpx; font-weight: 700; color: #3C3C3C;
}

.draw-card__cost {
  font-size: 24rpx; color: #A0A0A0; margin-top: 4rpx;
}

.draw-card__rates {
  display: flex; flex-wrap: wrap; gap: 12rpx; margin-bottom: 28rpx;
  padding: 20rpx; background: #F5F5F5; border-radius: 16rpx;
}

.draw-card__rate-item { display: flex; align-items: center; gap: 6rpx; }

.draw-card__rate-name { font-size: 24rpx; font-weight: 500; }

.draw-card__rate-pct { font-size: 24rpx; color: #A0A0A0; }

.draw-card__actions { display: flex; gap: 16rpx; }

.draw-card__btn {
  flex: 1; height: 80rpx; line-height: 80rpx;
  border-radius: 32rpx; font-size: 30rpx; font-weight: 700;
  text-align: center; border: none; padding: 0;
}

.draw-card__btn::after { border: none; }

.draw-card__btn--primary { background: linear-gradient(135deg, #46A800, #58CC02); color: #FFFFFF; box-shadow: var(--shadow-glow-green); }
.draw-card__btn--primary:active { opacity: 0.7; }
.draw-card__btn[disabled] { background: #CFCFCF; color: #FFFFFF; }

.draw-card__remaining {
  text-align: center; padding: 12rpx 0 8rpx;
  font-size: 24rpx; color: #8E8E93;
}

.draw-card__remaining-num { font-weight: 700; color: #007AFF; font-size: 28rpx; }

.draw-card__limit-hint {
  text-align: center; padding: 16rpx 0 0;
  font-size: 24rpx; color: #A0A0A0;
}
