.action-sheet-overlay {
  position: fixed; top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0); z-index: 150; pointer-events: none;
  transition: background 0.3s;
}

.action-sheet-overlay--visible {
  background: rgba(0,0,0,0.4); pointer-events: auto;
}

.action-sheet {
  position: absolute; bottom: 0; left: 0; right: 0;
  background: #FFFFFF; border-radius: 20rpx 20rpx 0 0;
  padding: 16rpx 32rpx calc(32rpx + env(safe-area-inset-bottom));
  transform: translateY(100%);
  transition: transform 0.35s cubic-bezier(0.32, 0.72, 0, 1);
}

.action-sheet--visible { transform: translateY(0); }

.action-sheet__handle { display: flex; justify-content: center; padding: 12rpx 0 20rpx; }

.action-sheet__handle-bar {
  width: 72rpx; height: 8rpx; background: #D1D1D6; border-radius: 4rpx;
}

.action-sheet__title {
  font-size: 30rpx; font-weight: 600; text-align: center;
  margin-bottom: 24rpx;
}

.action-sheet__body { padding-bottom: 24rpx; }

.action-sheet__actions { display: flex; flex-direction: column; gap: 12rpx; }

.action-sheet__btn {
  width: 100%; height: 88rpx; line-height: 88rpx;
  border-radius: 20rpx; font-size: 30rpx; font-weight: 600;
  text-align: center; border: none; padding: 0;
}

.action-sheet__btn::after { border: none; }

.action-sheet__btn--primary { background: #007AFF; color: #FFFFFF; }

.action-sheet__btn--cancel { background: #F2F2F7; color: #8E8E93; }
