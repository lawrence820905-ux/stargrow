<view class="action-sheet-overlay {{visible ? 'action-sheet-overlay--visible' : ''}}" bindtap="onClose">
  <view class="action-sheet {{visible ? 'action-sheet--visible' : ''}}" catchtap="">
    <view class="action-sheet__handle">
      <view class="action-sheet__handle-bar"></view>
    </view>
    <view class="action-sheet__title" wx:if="{{title}}">{{title}}</view>
    <view class="action-sheet__body">
      <slot></slot>
    </view>
    <view class="action-sheet__actions">
      <button class="action-sheet__btn action-sheet__btn--primary" bindtap="onConfirm" wx:if="{{showConfirm}}">
        {{confirmText}}
      </button>
      <button class="action-sheet__btn action-sheet__btn--cancel" bindtap="onClose">
        {{cancelText}}
      </button>
    </view>
  </view>
</view>
