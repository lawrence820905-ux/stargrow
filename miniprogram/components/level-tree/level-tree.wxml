<view class="level-tree">
  <!-- 圆形进度环 + 孩子头像 -->
  <view class="level-tree__ring-wrap">
    <canvas
      type="2d"
      id="progressCanvas"
      class="level-tree__canvas"
    />
    <view class="level-tree__avatar-inner">
      <image
        wx:if="{{child.avatarUrl}}"
        class="level-tree__avatar-img"
        src="{{child.avatarUrl}}"
        mode="aspectFill"
      />
      <view wx:else class="level-tree__avatar-placeholder">
        <text>{{child.name ? child.name[0] : '🌰'}}</text>
      </view>
    </view>
  </view>
  <text class="level-tree__name">{{child.name || '孩子'}} · Lv{{level}} {{levelInfo.name}}</text>
  <text class="level-tree__progress-text" wx:if="{{progress.pointsToNext > 0}}">
    距离下一级还需 {{progress.pointsToNext}} 积分
  </text>
  <text class="level-tree__progress-text" wx:else>已达最高等级!</text>
</view>
