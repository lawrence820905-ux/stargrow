/* 鍦嗗舰杩涘害鐜?+ 瀛╁瓙澶村儚 */
.level-tree {
  display: flex; flex-direction: column; align-items: center;
  padding: 32rpx 32rpx 24rpx;
}

.level-tree__ring-wrap {
  position: relative;
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 20rpx;
}

.level-tree__canvas {
  position: absolute;
  top: 0; left: 0;
  width: 200rpx;
  height: 200rpx;
}

/* 涓績瀛╁瓙澶村儚 */
.level-tree__avatar-inner {
  position: absolute;
  top: 50%; left: 50%;
  transform: translate(-50%, -50%);
  width: 148rpx;
  height: 148rpx;
  border-radius: 50%;
  overflow: hidden;
  background: #FFFFFF;
  box-shadow: 0 4px 16px rgba(0,0,0,0.10);
}

.level-tree__avatar-img {
  width: 100%;
  height: 100%;
}

.level-tree__avatar-placeholder {
  width: 100%;
  height: 100%;
  background: linear-gradient(135deg, #EEF8FF, #F6EEFF);
  display: flex; align-items: center; justify-content: center;
  font-size: 64rpx;
}

.level-tree__name {
  font-size: 32rpx; font-weight: 800; color: #3C3C3C;
  margin-bottom: 8rpx;
}

.level-tree__progress-text {
  font-size: 24rpx; color: #A0A0A0; font-weight: 500;
}
