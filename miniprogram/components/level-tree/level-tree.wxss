.level-tree {
  display: flex; flex-direction: column; align-items: center;
  padding: 40rpx 32rpx;
}

.level-tree__icon {
  font-size: 120rpx; line-height: 1; margin-bottom: 16rpx;
  transition: transform 0.5s cubic-bezier(0.34, 1.56, 0.64, 1);
}

.level-tree__name {
  font-size: 32rpx; font-weight: 700; color: #1d1d1f; margin-bottom: 20rpx;
}

.level-tree__progress-bar {
  width: 100%; height: 12rpx; background: #C6C6C8;
  border-radius: 6rpx; overflow: hidden; margin-bottom: 12rpx;
}

.level-tree__progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #34C759, #007AFF);
  border-radius: 6rpx; transition: width 0.5s ease;
}

.level-tree__progress-text { font-size: 24rpx; color: #8E8E93; }
