.draw-result-overlay {
  position: fixed; top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0); z-index: 200;
  display: flex; align-items: flex-end; justify-content: center;
  pointer-events: none; transition: background 0.3s;
}

.draw-result-overlay--visible {
  background: rgba(0,0,0,0.4); pointer-events: auto;
}

.draw-result-sheet {
  width: 100%; background: #FFFFFF;
  border-radius: 20rpx 20rpx 0 0;
  padding: 48rpx 32rpx calc(48rpx + env(safe-area-inset-bottom));
  transform: translateY(100%);
  transition: transform 0.35s cubic-bezier(0.32, 0.72, 0, 1);
  position: relative; overflow: hidden;
}

.draw-result-sheet--visible { transform: translateY(0); }

.draw-result-sheet__rarity-bg {
  position: absolute; top: 0; left: 0; right: 0; height: 160rpx; opacity: 0.15;
}

.draw-result-sheet__content {
  display: flex; flex-direction: column; align-items: center;
  padding: 32rpx 0 40rpx;
}

.draw-result-sheet__emoji { font-size: 96rpx; margin-bottom: 16rpx; }

.draw-result-sheet__title {
  font-size: 28rpx; color: #8E8E93; margin-bottom: 8rpx;
}

.draw-result-sheet__prize {
  font-size: 40rpx; font-weight: 700; color: #1d1d1f;
  text-align: center; margin-bottom: 8rpx;
}

.draw-result-sheet__detail {
  font-size: 28rpx; color: #007AFF; font-weight: 600;
}

.draw-result-sheet__cost {
  font-size: 24rpx; color: #C7C7CC; margin-top: 12rpx;
}

.draw-result-sheet__btn {
  width: 100%; height: 96rpx; line-height: 96rpx;
  background: #007AFF; color: #FFFFFF;
  border-radius: 20rpx; font-size: 32rpx; font-weight: 600;
  text-align: center; border: none;
}

.draw-result-sheet__btn::after { border: none; }
