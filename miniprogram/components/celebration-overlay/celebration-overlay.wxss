.co {
  position: fixed; top: 0; left: 0; right: 0; bottom: 0;
  z-index: 1000;
  display: flex; align-items: center; justify-content: center;
  background: rgba(0,0,0,0.5);
  opacity: 0; pointer-events: none;
  transition: opacity 0.3s ease;
}
.co--visible { opacity: 1; pointer-events: auto; }

.co__card {
  display: flex; flex-direction: column; align-items: center; gap: 12rpx;
  padding: 64rpx 56rpx;
  background: #FFFFFF;
  border-radius: 40rpx;
  box-shadow: 0 20px 60px rgba(0,0,0,0.3);
  transform: scale(0);
  transition: transform 0.5s cubic-bezier(0.34, 1.56, 0.64, 1);
}

.co__card--pop {
  transform: scale(1);
}

.co__icon { font-size: 100rpx; }

.co__title {
  font-size: 40rpx; font-weight: 800; color: #3C3C3C;
  text-align: center; letter-spacing: -0.5rpx;
}

.co__subtitle {
  font-size: 28rpx; color: #8E8E93;
  text-align: center;
}

.co__hint {
  margin-top: 24rpx;
  font-size: 24rpx; color: #CFCFCF;
}
