<view class="empty-state">
  <text class="empty-state__icon">{{icon}}</text>
  <text class="empty-state__text">{{text}}</text>
  <text class="empty-state__hint" wx:if="{{hint}}">{{hint}}</text>
  <button class="empty-state__btn" wx:if="{{actionText}}" bindtap="onAction">{{actionText}}</button>
</view>
