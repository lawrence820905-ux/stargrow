/* Duolingo Empty State — 改进版 */
.empty-state {
  display: flex; flex-direction: column; align-items: center;
  justify-content: center; padding: 80rpx 32rpx;
}

.empty-state__icon { font-size: 80rpx; margin-bottom: 24rpx; opacity: 0.5; }

.empty-state__text {
  font-size: 28rpx; color: #3C3C3C; text-align: center; line-height: 1.5; font-weight: 600;
  margin-bottom: 8rpx;
}

.empty-state__hint {
  font-size: 24rpx; color: #A0A0A0; text-align: center; line-height: 1.5; font-weight: 400;
  margin-bottom: 24rpx; max-width: 480rpx;
}

.empty-state__btn {
  margin-top: 16rpx; padding: 16rpx 40rpx;
  background: linear-gradient(135deg, #46A800, #58CC02); color: #FFFFFF;
  border-radius: 32rpx; font-size: 28rpx; font-weight: 700; border: none;
  box-shadow: 0 4px 16px rgba(88,204,2,0.25);
  transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
}

.empty-state__btn::after { border: none; }
.empty-state__btn:active { transform: scale(0.96); opacity: 0.85; }
