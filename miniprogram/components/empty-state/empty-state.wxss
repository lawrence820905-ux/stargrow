.empty-state {
  display: flex; flex-direction: column; align-items: center;
  justify-content: center; padding: 80rpx 32rpx;
}

.empty-state__icon { font-size: 80rpx; margin-bottom: 24rpx; }

.empty-state__text {
  font-size: 28rpx; color: #8E8E93; text-align: center; line-height: 1.5;
}

.empty-state__btn {
  margin-top: 24rpx; padding: 16rpx 40rpx;
  background: #007AFF; color: #FFFFFF;
  border-radius: 20rpx; font-size: 28rpx; font-weight: 500; border: none;
}

.empty-state__btn::after { border: none; }
